---
/**
 * /_design — the design system showcase. This page is the project's
 * living style guide; it is not linked from anywhere visitor-facing
 * and is excluded from the sitemap (filter in astro.config.mjs).
 *
 * Reading order matches docs/DESIGN-PRINCIPLES.md:
 *   1. Color tokens with measured WCAG contrast
 *   2. Type scale with real copy from COPY-GUIDE.md
 *   3. Spacing scale
 *   4. Grid demonstration
 *   5. Component primitives (Button, Link, Card, Callout, Figure, Form, Table, Citation)
 *
 * Anything that fails its target on this page does not ship.
 */
import "../styles/global.css";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";
import Card from "../components/Card.astro";
import Callout from "../components/Callout.astro";
import Figure from "../components/Figure.astro";
import CitationBlock from "../components/CitationBlock.astro";
import FormField from "../components/FormField.astro";
import Footnote from "../components/Footnote.astro";
import ColorSwatch from "../components/ColorSwatch.astro";
import TypeSpecimen from "../components/TypeSpecimen.astro";

// Light-mode token hexes mirror the values declared in src/styles/global.css.
// We list them here for the contrast calculator; the actual rendering uses
// CSS vars so dark mode swaps automatically.
const LIGHT = {
  background: "#FAF7F2",
  surface: "#F2EDE4",
  surfaceElevated: "#FFFFFF",
  ink: "#1A1715",
  inkMuted: "#5C544D",
  inkSubtle: "#8A8077",
  accent: "#B7472A",
  accentDim: "#8E3520",
  accentInk: "#FAF7F2",
  border: "#E0D9CC",
  borderStrong: "#B8AC99",
  focusRing: "#2D5A87",
  success: "#3F6B3F",
  warning: "#A86B12",
  error: "#9A2E1F",
} as const;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>3MIP — design system</title>
    <style>
      /* Local utility for the showcase only. */
      .section { padding-block: var(--space-7); border-bottom: 1px solid var(--color-border); }
      .section:last-of-type { border-bottom: 0; }
      .container { max-width: var(--content-max); padding-inline: var(--space-4); margin-inline: auto; }
      @media (min-width: 768px) { .container { padding-inline: var(--space-5); } }
      .swatch-grid { display: grid; gap: var(--space-3); grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr)); }
      .grid-demo {
        display: grid; gap: var(--space-3);
        grid-template-columns: repeat(4, 1fr);
      }
      @media (min-width: 768px) { .grid-demo { grid-template-columns: repeat(6, 1fr); } }
      @media (min-width: 1024px) { .grid-demo { grid-template-columns: repeat(12, 1fr); } }
      .grid-demo > div {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: var(--space-2);
        text-align: center;
        font-size: var(--text-caption);
        color: var(--color-ink-muted);
        border-radius: var(--radius);
      }
      .space-row {
        display: grid;
        grid-template-columns: 6rem 1fr;
        align-items: center;
        gap: var(--space-4);
        padding-block: var(--space-2);
      }
      .space-row .bar { background: var(--color-accent); height: 0.5rem; border-radius: 2px; }
    </style>
  </head>
  <body>
    <header class="container" style="padding-block: var(--space-6);">
      <p class="text-caption" style="color: var(--color-ink-subtle); text-transform: uppercase; letter-spacing: 0.08em;">
        Internal · not linked from the public site
      </p>
      <h1 style="margin-top: var(--space-2);">3MIP design system</h1>
      <p class="text-body-lg" style="color: var(--color-ink-muted); max-width: 65ch; margin-top: var(--space-3);">
        This page renders every token, type setting, and component primitive used across the site.
        It is the QA artifact for Phase 1: any contrast pair that does not meet its WCAG target
        ships as <strong style="color: var(--color-error);">FAIL</strong> and is fixed before merge.
      </p>
    </header>

    <main class="container" id="main">

      <!-- ──────────────────────────────────────────────────────────────
           1. Color tokens
           ────────────────────────────────────────────────────────────── -->
      <section class="section" aria-labelledby="color-h">
        <h2 id="color-h">1 · Color tokens</h2>
        <p style="color: var(--color-ink-muted); margin-top: var(--space-2);">
          Each swatch shows the token value and its measured contrast against the surface it's most
          commonly placed on. Light-mode hexes are used for the calculation; dark mode is verified
          by switching the OS theme — both palettes hit the same WCAG targets.
        </p>

        <h3 style="margin-top: var(--space-5);">Text on background</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="ink"        hex={LIGHT.ink}        pairedWith={LIGHT.background} pairedName="background" kind="body" />
          <ColorSwatch name="ink-muted"  hex={LIGHT.inkMuted}   pairedWith={LIGHT.background} pairedName="background" kind="body" />
          <ColorSwatch name="ink-subtle" hex={LIGHT.inkSubtle}  pairedWith={LIGHT.background} pairedName="background" kind="large" />
        </div>

        <h3 style="margin-top: var(--space-5);">Accent and interactive</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="accent"     hex={LIGHT.accent}     pairedWith={LIGHT.background} pairedName="background" kind="large" />
          <ColorSwatch name="accent-ink" hex={LIGHT.accentInk}  pairedWith={LIGHT.accent}     pairedName="accent"     kind="body" />
          <ColorSwatch name="focus-ring" hex={LIGHT.focusRing}  pairedWith={LIGHT.background} pairedName="background" kind="ui" />
        </div>

        <h3 style="margin-top: var(--space-5);">Status</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="success"    hex={LIGHT.success}    pairedWith={LIGHT.background} pairedName="background" kind="body" />
          <ColorSwatch name="warning"    hex={LIGHT.warning}    pairedWith={LIGHT.background} pairedName="background" kind="body" />
          <ColorSwatch name="error"      hex={LIGHT.error}      pairedWith={LIGHT.background} pairedName="background" kind="body" />
        </div>

        <h3 style="margin-top: var(--space-5);">Surfaces and borders</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="surface"        hex={LIGHT.surface}        pairedWith={LIGHT.ink}        pairedName="ink (on surface)" kind="body" />
          <ColorSwatch name="surface-elev."  hex={LIGHT.surfaceElevated} pairedWith={LIGHT.ink}       pairedName="ink"              kind="body" />
          <ColorSwatch name="border"         hex={LIGHT.border}         pairedWith={LIGHT.background} pairedName="background"       kind="ui" />
          <ColorSwatch name="border-strong"  hex={LIGHT.borderStrong}   pairedWith={LIGHT.background} pairedName="background"       kind="ui" />
        </div>
      </section>

      <!-- ──────────────────────────────────────────────────────────────
           2. Type scale (real copy from docs/COPY-GUIDE.md examples)
           ────────────────────────────────────────────────────────────── -->
      <section class="section" aria-labelledby="type-h">
        <h2 id="type-h">2 · Type scale</h2>
        <p style="color: var(--color-ink-muted); margin-top: var(--space-2);">
          Source Serif 4 (display, H1, prose emphasis) + Inter (everything else). Both variable,
          both self-hosted. Lorem ipsum is forbidden by COPY-GUIDE.md, so every sample below
          is real copy that the site will ship.
        </p>

        <div style="margin-top: var(--space-4);">
          <TypeSpecimen token="display" family="serif" description="56/1.05/-2%" className="text-[3.5rem] leading-[1.05] tracking-[-0.02em]">
            Different models. Same question. One coordinated answer.
          </TypeSpecimen>
          <TypeSpecimen token="h1" family="serif" description="40/1.15/-1.5%" className="text-[2.5rem] leading-[1.15] tracking-[-0.015em]">
            About 3MIP
          </TypeSpecimen>
          <TypeSpecimen token="h2" family="sans" description="30/1.2/-1%" className="text-[1.875rem] leading-[1.2] tracking-[-0.01em] font-semibold">
            Why Bangladesh is the first case
          </TypeSpecimen>
          <TypeSpecimen token="h3" family="sans" description="22/1.3" className="text-[1.375rem] leading-[1.3] font-semibold">
            Advisory committee
          </TypeSpecimen>
          <TypeSpecimen token="h4" family="sans" description="18/1.35" className="text-[1.125rem] leading-[1.35] font-semibold">
            What participation involves
          </TypeSpecimen>
          <TypeSpecimen token="body-lg" family="sans" description="18/1.65" className="text-[1.125rem] leading-[1.65]">
            3MIP is a community of climate-migration modelers who agree to apply their approaches
            to a shared benchmark case and synthesize the results.
          </TypeSpecimen>
          <TypeSpecimen token="body" family="sans" description="16/1.65" className="text-[1rem] leading-[1.65]">
            Bangladesh has 175.7 million people, much of it living in a low-lying delta. Bell et al.
            (2021) projected that migration toward Bangladesh's coast — not away from it — will
            continue through 2100 under all sea-level rise scenarios studied.
          </TypeSpecimen>
          <TypeSpecimen token="small" family="sans" description="14/1.5" className="text-[0.875rem] leading-[1.5]">
            Source: United Nations Population Fund, State of World Population 2025.
          </TypeSpecimen>
          <TypeSpecimen token="caption" family="sans" description="12/1.4/+2%" className="text-[0.75rem] leading-[1.4] tracking-[0.02em] uppercase font-medium">
            Figure 1 · Illustrative
          </TypeSpecimen>
        </div>
      </section>

      <!-- ──────────────────────────────────────────────────────────────
           3. Spacing scale
           ────────────────────────────────────────────────────────────── -->
      <section class="section" aria-labelledby="space-h">
        <h2 id="space-h">3 · Spacing scale</h2>
        <p style="color: var(--color-ink-muted); margin-top: var(--space-2);">
          8pt base. Vertical rhythm uses space-3 between paragraphs, space-7 between sections,
          space-8 between major page regions.
        </p>
        <div style="margin-top: var(--space-4);">
          {[
            ["space-1", "4px"], ["space-2", "8px"], ["space-3", "16px"],
            ["space-4", "24px"], ["space-5", "32px"], ["space-6", "48px"],
            ["space-7", "64px"], ["space-8", "96px"], ["space-9", "128px"],
          ].map(([token, px]) => (
            <div class="space-row">
              <div class="text-small" style="color: var(--color-ink-muted);">
                <span style="color: var(--color-ink); font-weight: 500;">{token}</span> · {px}
              </div>
              <div class="bar" style={`width: ${px};`}></div>
            </div>
          ))}
        </div>
      </section>

      <!-- ──────────────────────────────────────────────────────────────
           4. Grid demo
           ────────────────────────────────────────────────────────────── -->
      <section class="section" aria-labelledby="grid-h">
        <h2 id="grid-h">4 · Grid</h2>
        <p style="color: var(--color-ink-muted); margin-top: var(--space-2);">
          12 columns at ≥1024px, 6 columns at 768–1023, 4 columns at &lt;768. Max content width 1280px.
          Resize this window to see the rearrangement.
        </p>
        <div class="grid-demo" style="margin-top: var(--space-4);">
          {Array.from({ length: 12 }, (_, i) => <div>col {i + 1}</div>)}
        </div>
      </section>

      <!-- ──────────────────────────────────────────────────────────────
           5. Components
           ────────────────────────────────────────────────────────────── -->
      <section class="section" aria-labelledby="comp-h">
        <h2 id="comp-h">5 · Components</h2>

        <h3 style="margin-top: var(--space-5);">Buttons</h3>
        <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-3);">
          <Button>Register</Button>
          <Button variant="secondary">Read the case</Button>
          <Button variant="ghost">Cancel</Button>
          <Button disabled>Submitting…</Button>
          <Button href="https://conference.iemss.org/streams/" external>iEMSs program</Button>
        </div>

        <h3 style="margin-top: var(--space-6);">Links</h3>
        <p>
          In prose, the dataset citation reads <Link href="/data/">curated input data</Link> for the
          coastal Bangladesh case. Standalone navigation uses
          <Link href="/about/" variant="standalone">About</Link>. External references like
          <Link href="https://cpree.princeton.edu/news/2024/researchers-around-world-attend-climate-migration-workshop-princeton">Princeton C-PREE</Link>
          carry an unobtrusive glyph.
        </p>

        <h3 style="margin-top: var(--space-6);">Cards</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <Card>
            <p class="text-caption" style="color: var(--color-ink-subtle); text-transform: uppercase; letter-spacing: 0.08em;">Dataset</p>
            <h4 style="margin-top: var(--space-2);">GHSL Population Grid</h4>
            <p class="text-small" style="color: var(--color-ink-muted); margin-top: var(--space-2);">
              Schiavina, Freire, MacManus (2019). 250m resolution. CC BY 4.0.
            </p>
          </Card>
          <Card href="/outputs/">
            <p class="text-caption" style="color: var(--color-ink-subtle); text-transform: uppercase; letter-spacing: 0.08em;">Webinar</p>
            <h4 style="margin-top: var(--space-2);">February 2025 webinar</h4>
            <p class="text-small" style="color: var(--color-ink-muted); margin-top: var(--space-2);">
              45 min · Speaker [VERIFY]
            </p>
          </Card>
          <Card emphasized>
            <p class="text-caption" style="color: var(--color-ink-subtle); text-transform: uppercase; letter-spacing: 0.08em;">News</p>
            <h4 style="margin-top: var(--space-2);">3MIP launches</h4>
            <p class="text-small" style="color: var(--color-ink-muted); margin-top: var(--space-2);">
              October 2025 — registration opens for the coastal Bangladesh benchmark case.
            </p>
          </Card>
        </div>

        <h3 style="margin-top: var(--space-6);">Callouts</h3>
        <div style="display: grid; gap: var(--space-3); margin-top: var(--space-3);">
          <Callout variant="note" label="The shared question">
            Net internal migration in coastal Bangladesh districts, 2025–2050, under SSP2-4.5.
            Teams may extend to SSP1-2.6 and SSP5-8.5 as sensitivity scenarios.
          </Callout>
          <Callout variant="citation">
            Bell, A. R., Wrathall, D. J., Mueller, V., et al. (2021). Migration towards Bangladesh
            coastlines projected to increase with sea-level rise through 2100. <em>Environmental
            Research Letters</em>, 16(2), 024045.
          </Callout>
          <Callout variant="caution" label="Empty state">
            Working papers from participating teams will appear here as they are released.
          </Callout>
        </div>

        <h3 style="margin-top: var(--space-6);">Figure (placeholder for signature visualization)</h3>
        <Figure
          illustrative
          caption="Six model archetypes applied to the same Bangladesh migration question yield divergent spatial patterns. 3MIP synthesizes the disagreement rather than averaging it away."
          source="3MIP. Synthetic data."
        >
          <div style="aspect-ratio: 16 / 9; background: var(--color-surface); border: 1px dashed var(--color-border-strong); display: flex; align-items: center; justify-content: center; border-radius: var(--radius);">
            <p class="text-caption" style="color: var(--color-ink-subtle);">SignatureViz lands here in Phase 2</p>
          </div>
          <p slot="long-description" class="text-small" style="color: var(--color-ink-muted); margin-top: var(--space-2);">
            Long-form text alternative: in the final figure, each of six small panels shows the same
            coastal silhouette of Bangladesh under a different model archetype (ABM, gravity,
            radiation, integrated assessment, machine learning, cellular automaton). The color ramp
            indicates synthetic net migration intensity. Panels share a legend, a scale bar, and the
            common research question stated above.
          </p>
        </Figure>

        <h3 style="margin-top: var(--space-6);">Citation block</h3>
        <CitationBlock
          authors="Bell, A. R., Wrathall, D. J., Mueller, V., Chen, J., Oppenheimer, M., et al."
          year={2021}
          title="Migration towards Bangladesh coastlines projected to increase with sea-level rise through 2100"
          venue="Environmental Research Letters"
          reference="16(2), 024045"
          doi="10.1088/1748-9326/abdc5b"
        />

        <h3 style="margin-top: var(--space-6);">Footnote markers</h3>
        <p>
          Bangladesh has 175.7 million people<Footnote id="1" />, much of it living in a low-lying
          delta<Footnote id="2" />. The footnote markers point to entries in an end-of-page list
          (rendered as a real component on the Case and Outputs pages, not on this showcase).
        </p>

        <h3 style="margin-top: var(--space-6);">Form inputs</h3>
        <form aria-label="Registration form preview" style="max-width: 32rem;">
          <FormField id="name" name="name" label="Name" required placeholder="First and last" />
          <FormField id="email" name="email" type="email" label="Email" required />
          <FormField
            id="approach"
            name="approach"
            type="select"
            label="Modeling approach"
            required
            options={[
              { value: "abm", label: "Agent-based" },
              { value: "gravity", label: "Gravity" },
              { value: "radiation", label: "Radiation" },
              { value: "iam", label: "Integrated assessment" },
              { value: "ml", label: "Machine learning" },
              { value: "other", label: "Other" },
            ]}
          />
          <FormField
            id="question"
            name="question"
            type="textarea"
            label="Research question of interest"
            required
            help="2–4 sentences on what you intend to study with the curated dataset."
          />
          <FormField
            id="orcid"
            name="orcid"
            label="ORCID"
            pattern="\d{4}-\d{4}-\d{4}-\d{4}"
            help="Optional. Format: 0000-0000-0000-0000"
          />
          <FormField
            id="broken"
            name="broken"
            label="Field with error (preview)"
            error="This field is required."
          />
          <Button type="submit">Submit registration</Button>
        </form>

        <h3 style="margin-top: var(--space-6);">Table</h3>
        <p style="color: var(--color-ink-muted);">
          Static rendering. Sortable behavior (≤2KB client JS) lands in Phase 4A on the Data page.
        </p>
        <table style="margin-top: var(--space-3);">
          <thead>
            <tr>
              <th scope="col">Dataset</th>
              <th scope="col">Variable</th>
              <th scope="col">Resolution</th>
              <th scope="col">License</th>
              <th scope="col">DOI</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>GHSL Population Grid</td>
              <td>population</td>
              <td>250 m</td>
              <td>CC BY 4.0</td>
              <td><Link href="https://doi.org/10.2905/0C6B9751-A71F-4062-830B-43C9F432370F">10.2905/0C6B9751…</Link></td>
            </tr>
            <tr>
              <td>Sorichetta et al. flows</td>
              <td>migration</td>
              <td>district</td>
              <td>CC BY 4.0</td>
              <td><Link href="https://doi.org/10.1038/sdata.2016.66">10.1038/sdata.2016.66</Link></td>
            </tr>
            <tr>
              <td>Hassani et al. salinity</td>
              <td>soil salinity</td>
              <td>30 arc-sec</td>
              <td>CC BY 4.0</td>
              <td><Link href="https://doi.org/10.1073/pnas.2013771117">10.1073/pnas.2013771117</Link></td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- ──────────────────────────────────────────────────────────────
           6. Motion preferences
           ────────────────────────────────────────────────────────────── -->
      <section class="section" aria-labelledby="motion-h">
        <h2 id="motion-h">6 · Motion</h2>
        <p style="color: var(--color-ink-muted); margin-top: var(--space-2);">
          Two durations (150ms hover, 250ms layout). `prefers-reduced-motion: reduce` collapses
          everything to 0.01ms via the rule in <code>global.css</code>. Hover any button above
          while reduced motion is on (System Settings → Accessibility → Display → Reduce motion)
          to verify.
        </p>
      </section>
    </main>

    <footer class="container" style="padding-block: var(--space-6); color: var(--color-ink-subtle); font-size: var(--text-small);">
      Internal design system · not shipped to visitors · excluded from sitemap · noindex.
    </footer>
  </body>
</html>
