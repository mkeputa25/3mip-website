---
/**
 * /design — the design system showcase, v2 (DECISIONS-V2.md).
 *
 * Not linked from the public site; excluded from sitemap; noindex.
 *
 * Order:
 *   1. Color tokens with measured WCAG contrast (incl. C1–C3 annotations)
 *   2. Fraunces axis specimens (display vs text optical sizes, SOFT/WONK,
 *      old-style vs lining figures)
 *   3. Type scale with real copy
 *   4. Editorial register: eyebrows, section dividers, hairlines
 *   5. Spacing scale
 *   6. Grid demonstration
 *   7. Component primitives (rendered under v2 tokens; full component
 *      restyle lands in Phase 4e)
 *   8. Signature visualization (atlas-plate rebuild lands in Phase 2c)
 *
 * Anything that fails its target on this page does not ship — except the
 * two documented exceptions (C2 eyebrow near-miss; see annotations).
 */
import "../styles/global.css";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";
import Card from "../components/Card.astro";
import Callout from "../components/Callout.astro";
import CitationBlock from "../components/CitationBlock.astro";
import FormField from "../components/FormField.astro";
import ColorSwatch from "../components/ColorSwatch.astro";
import SignatureViz from "../components/SignatureViz.astro";
import RevealScript from "../components/RevealScript.astro";
import HeroAmbience from "../components/HeroAmbience.astro";

// v2.1 token hexes (DECISIONS-V2 V8) — mirrors src/styles/global.css.
const LIGHT = {
  background: "#FFFFFF",
  surface: "#F8F6F3",
  plate: "#F5EFE4",
  surfaceElevated: "#FFFFFF",
  ink: "#1A1612",
  inkMuted: "#6B6358",
  inkSubtle: "#9A9085",
  accent: "#B85A35",
  accentDim: "#D08A6E",
  accentDeep: "#6B1F1F",
  accentInk: "#FFFFFF",
  border: "#ECE9E4",
  borderStrong: "#D6D2CB",
  focusRing: "#2F6CB3",
  success: "#3F6D2F",
  warning: "#C88A1A",
  error: "#8E2424",
} as const;

const RAMP = ["#F5EFE4", "#E8B98A", "#D08A6E", "#B85A35", "#8E3A22", "#6B1F1F"] as const;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#F5EFE4" />
    <title>3MIP — design system v2</title>
    <style>
      .section { padding-block: var(--space-7); border-bottom: 1px solid var(--color-border); }
      .section:last-of-type { border-bottom: 0; }
      .container { max-width: var(--content-max); padding-inline: var(--space-4); margin-inline: auto; }
      @media (min-width: 768px) { .container { padding-inline: var(--space-5); } }
      .swatch-grid { display: grid; gap: var(--space-3); grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr)); }
      .grid-demo { display: grid; gap: var(--space-3); grid-template-columns: repeat(4, 1fr); }
      @media (min-width: 768px) { .grid-demo { grid-template-columns: repeat(6, 1fr); } }
      @media (min-width: 1024px) { .grid-demo { grid-template-columns: repeat(12, 1fr); } }
      .grid-demo > div {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        padding: var(--space-2);
        text-align: center;
        font-family: var(--font-sans);
        font-size: var(--text-caption);
        color: var(--color-ink-muted);
        border-radius: var(--radius);
      }
      .space-row { display: grid; grid-template-columns: 6rem 1fr; align-items: center; gap: var(--space-4); padding-block: var(--space-2); }
      .space-row .bar { background: var(--color-accent); height: 0.5rem; border-radius: 2px; }
      .note { font-family: var(--font-sans); font-size: var(--text-small); color: var(--color-ink-muted); max-width: 65ch; }
      .annotation { font-family: var(--font-sans); font-size: var(--text-caption); color: var(--color-accent-deep); max-width: 65ch; }
      .specimen { padding-block: var(--space-4); border-bottom: 1px solid var(--color-border); }
      .specimen__meta { font-family: var(--font-sans); font-size: var(--text-caption); color: var(--color-ink-muted); letter-spacing: 0.02em; margin-bottom: var(--space-2); }
      .ramp-row { display: flex; gap: 0; border: 1px solid var(--color-border); border-radius: 2px; overflow: hidden; width: fit-content; }
      .ramp-row span { display: inline-block; width: 56px; height: 32px; }
      .ramp-labels { display: flex; gap: 0; width: fit-content; }
      .ramp-labels span { display: inline-block; width: 56px; font-family: var(--font-mono); font-size: 10px; color: var(--color-ink-muted); text-align: center; }
    </style>
  </head>
  <body>
    <header class="container" style="padding-block: var(--space-6);">
      <p class="eyebrow">Internal · not linked from the public site</p>
      <h1 style="margin-top: var(--space-2);">3MIP design system, v2.1</h1>
      <p class="note" style="font-size: var(--text-body-lg); margin-top: var(--space-3);">
        Distill/Quanta register: Fraunces and Geist on a white gallery ground; the parchment
        survives as the plate beneath figures; terracotta is the sole chromatic signal;
        motion explains or orients, never decorates. Light-only. Every contrast pair below
        shows its measured WCAG ratio.
      </p>
    </header>

    <main class="container" id="main">

      <!-- 1. Color tokens -->
      <section class="section" aria-labelledby="color-h">
        <h2 id="color-h">1 · Color tokens</h2>
        <p class="note" style="margin-top: var(--space-2);">
          Single light theme on a pure-white gallery ground. Cards sit on warm-neutral
          surface; figures mount on the parchment plate. The focus ring is the only blue
          on the site.
        </p>

        <h3 style="margin-top: var(--space-5);">Text on the three grounds</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="ink"        hex={LIGHT.ink}       pairedWith={LIGHT.background} pairedName="white" kind="body" />
          <ColorSwatch name="ink"        hex={LIGHT.ink}       pairedWith={LIGHT.plate}      pairedName="plate" kind="body" />
          <ColorSwatch name="ink-muted"  hex={LIGHT.inkMuted}  pairedWith={LIGHT.background} pairedName="white" kind="body" />
          <ColorSwatch name="ink-muted"  hex={LIGHT.inkMuted}  pairedWith={LIGHT.surface}    pairedName="surface" kind="body" />
          <ColorSwatch name="ink-muted"  hex={LIGHT.inkMuted}  pairedWith={LIGHT.plate}      pairedName="plate" kind="body" />
        </div>
        <p class="annotation" style="margin-top: var(--space-3);">
          C1 — ink-subtle #9A9085 measures 2.74:1 and is therefore restricted to decorative
          glyphs (compass marks, separators). All text formerly in ink-subtle now uses ink-muted.
          It is intentionally absent from the text swatches above.
        </p>

        <h3 style="margin-top: var(--space-5);">Accent and interactive</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="accent"      hex={LIGHT.accent}     pairedWith={LIGHT.background} pairedName="white" kind="body" />
          <ColorSwatch name="accent"      hex={LIGHT.accent}     pairedWith={LIGHT.plate}      pairedName="plate" kind="large" />
          <ColorSwatch name="accent-deep" hex={LIGHT.accentDeep} pairedWith={LIGHT.background} pairedName="white" kind="body" />
          <ColorSwatch name="accent-ink"  hex={LIGHT.accentInk}  pairedWith={LIGHT.accent}     pairedName="accent" kind="body" />
          <ColorSwatch name="focus-ring"  hex={LIGHT.focusRing}  pairedWith={LIGHT.background} pairedName="white" kind="ui" />
        </div>
        <p class="annotation" style="margin-top: var(--space-3);">
          Usage rule (V8): accent on white is 4.61:1 — AA for normal text with no margin.
          Body-size accent text uses accent-deep or ink; #B85A35 is reserved for large text,
          UI, and graphics. C2 carries over on plate grounds (4.03:1): eyebrows on plates
          remain the one documented near-miss, always redundant beside a compliant heading.
          accent-dim (2.78:1 on white) is fills and borders only, never text.
        </p>

        <h3 style="margin-top: var(--space-5);">Status</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="success" hex={LIGHT.success} pairedWith={LIGHT.background} pairedName="background" kind="body" />
          <ColorSwatch name="error"   hex={LIGHT.error}   pairedWith={LIGHT.background} pairedName="background" kind="body" />
        </div>
        <p class="annotation" style="margin-top: var(--space-3);">
          C3 — warning #C88A1A measures 2.58:1 and never carries text or sole meaning; it
          survives only as the caution callout's border, always paired with a label in ink.
          [VERIFY]/[PENDING] tags now render in accent-deep (9.97:1).
        </p>

        <h3 style="margin-top: var(--space-5);">Surfaces and rules</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <ColorSwatch name="surface"       hex={LIGHT.surface}        pairedWith={LIGHT.ink} pairedName="ink (on surface)" kind="body" />
          <ColorSwatch name="surface-elev." hex={LIGHT.surfaceElevated} pairedWith={LIGHT.ink} pairedName="ink"             kind="body" />
        </div>

        <h3 style="margin-top: var(--space-5);">Signature-viz sequential ramp</h3>
        <div class="ramp-row" style="margin-top: var(--space-3);" aria-label="Six-stop sequential ramp from parchment to deep oxblood">
          {RAMP.map((hex) => <span style={`background:${hex}`}></span>)}
        </div>
        <div class="ramp-labels">
          {RAMP.map((hex) => <span>{hex.slice(1)}</span>)}
        </div>
        <p class="note" style="margin-top: var(--space-2);">No blue in any figure.</p>
      </section>

      <!-- 2. Fraunces axis specimens -->
      <section class="section" aria-labelledby="axes-h">
        <h2 id="axes-h">2 · Fraunces axes</h2>
        <p class="note" style="margin-top: var(--space-2);">
          One variable file carries opsz, wght, SOFT, and WONK. Display settings are warm and
          wonky; text settings are sober. The difference below is the system's voice.
        </p>

        <div class="specimen">
          <p class="specimen__meta">display — opsz 96 · SOFT 50 · WONK 1 · weight 500</p>
          <p style="font-family: var(--font-serif); font-variation-settings: 'opsz' 96, 'SOFT' 50, 'WONK' 1; font-weight: 500; font-size: 3.5rem; line-height: 1.05; margin: 0;">
            Different models. Same question.
          </p>
        </div>

        <div class="specimen">
          <p class="specimen__meta">wordmark — opsz 72 · SOFT 100 · WONK 1 · weight 500</p>
          <p style="font-family: var(--font-serif); font-variation-settings: 'opsz' 72, 'SOFT' 100, 'WONK' 1; font-weight: 500; font-size: 3rem; margin: 0;">
            3MIP
          </p>
        </div>

        <div class="specimen">
          <p class="specimen__meta">text — opsz 14 · SOFT 0 · WONK 0 · weight 400 · old-style figures (onum)</p>
          <p style="margin: 0; max-width: 65ch;">
            Bangladesh has 175.7 million people, much of it living in a low-lying delta.
            Bell et al. (2021) projected that migration toward Bangladesh's coast — not away
            from it — will continue through 2100 under all sea-level rise scenarios studied.
          </p>
        </div>

        <div class="specimen">
          <p class="specimen__meta">same text, lining figures (lnum) — used in tables and headings</p>
          <p style="margin: 0; max-width: 65ch; font-feature-settings: 'kern', 'liga', 'lnum';">
            Bangladesh has 175.7 million people. 2025–2050 baseline; extensions to 2100.
          </p>
        </div>

        <div class="specimen">
          <p class="specimen__meta">italic — Fraunces wght-italic file (true italics, not slanted roman)</p>
          <p style="margin: 0; font-style: italic;">
            Climatic Change · Environmental Research Letters · Bay of Bengal
          </p>
        </div>
      </section>

      <!-- 3. Type scale -->
      <section class="section" aria-labelledby="type-h">
        <h2 id="type-h">3 · Type scale</h2>
        <div style="margin-top: var(--space-4);">
          <div class="specimen">
            <p class="specimen__meta">h1 · Fraunces display axes · 40/1.15</p>
            <h1 style="margin: 0;">About 3MIP</h1>
          </div>
          <div class="specimen">
            <p class="specimen__meta">h2 · opsz 36 · SOFT 25 · 30/1.2</p>
            <h2 style="margin: 0;">Why Bangladesh is the first case</h2>
          </div>
          <div class="specimen">
            <p class="specimen__meta">h3 · opsz 24 · 22/1.3</p>
            <h3 style="margin: 0;">Advisory committee</h3>
          </div>
          <div class="specimen">
            <p class="specimen__meta">body-lg · Fraunces text · 18/1.65</p>
            <p style="font-size: var(--text-body-lg); margin: 0; max-width: 60ch;">
              3MIP is a community of climate-migration modelers who agree to apply their
              approaches to a shared benchmark case and synthesize the results.
            </p>
          </div>
          <div class="specimen">
            <p class="specimen__meta">body · Fraunces text · 16/1.65</p>
            <p style="margin: 0; max-width: 65ch;">
              Teams choose how to operationalize "migration" within their own model
              architecture. Where outputs diverge — and they will — the synthesis paper
              documents the divergence and the methodological choices that drive it.
            </p>
          </div>
          <div class="specimen">
            <p class="specimen__meta">small / metadata · Geist 400 · 14/1.5</p>
            <p style="font-family: var(--font-sans); font-size: var(--text-small); color: var(--color-ink-muted); margin: 0;">
              Source: United Nations Population Fund, State of World Population 2025.
            </p>
          </div>
          <div class="specimen">
            <p class="specimen__meta">mono / data attribution · Geist Mono · rare</p>
            <p style="font-family: var(--font-mono); font-size: var(--text-small); color: var(--color-ink-muted); margin: 0;">
              10.1088/1748-9326/abdc5b · GHS-POP R2019A · SSP2-4.5
            </p>
          </div>
        </div>
      </section>

      <!-- 4. Editorial register -->
      <section class="section" aria-labelledby="register-h">
        <h2 id="register-h">4 · Editorial register</h2>

        <h3 style="margin-top: var(--space-5);">Eyebrow</h3>
        <div style="margin-top: var(--space-3);">
          <p class="eyebrow" style="margin: 0 0 var(--space-2);">Fig. 01 · Illustrative</p>
          <h3 style="margin: 0;">Six architectures, one question</h3>
        </div>

        <h3 style="margin-top: var(--space-6);">Section divider</h3>
        <div class="section-divider" style="margin-top: var(--space-3);">
          <p class="section-label" style="margin: 0;">Sec. 03 / The shared question</p>
        </div>

        <h3 style="margin-top: var(--space-6);">Dash conventions</h3>
        <p class="note" style="margin-top: var(--space-2);">
          En-dash for ranges: 2025–2050, July 12–16. Em-dash for parentheticals — like
          this one — set open. No text-transform: upper-case anywhere on the site;
          tracking carries the label register.
        </p>
      </section>

      <!-- 5. Spacing -->
      <section class="section" aria-labelledby="space-h">
        <h2 id="space-h">5 · Spacing scale</h2>
        <div style="margin-top: var(--space-4);">
          {[
            ["space-1", "4px"], ["space-2", "8px"], ["space-3", "16px"],
            ["space-4", "24px"], ["space-5", "32px"], ["space-6", "48px"],
            ["space-7", "64px"], ["space-8", "96px"], ["space-9", "128px"],
          ].map(([token, px]) => (
            <div class="space-row">
              <div class="note">
                <span style="color: var(--color-ink); font-weight: 500;">{token}</span> · {px}
              </div>
              <div class="bar" style={`width: ${px};`}></div>
            </div>
          ))}
        </div>
      </section>

      <!-- 6. Grid -->
      <section class="section" aria-labelledby="grid-h">
        <h2 id="grid-h">6 · Grid</h2>
        <p class="note" style="margin-top: var(--space-2);">
          12 columns at ≥1024px, 6 at 768–1023, 4 below. Max content width 1280px. The v2
          register permits asymmetric placement — section heads at column 2, captions hanging
          in the margin — demonstrated page-by-page in Phase 4e.
        </p>
        <div class="grid-demo" style="margin-top: var(--space-4);">
          {Array.from({ length: 12 }, (_, i) => <div>col {i + 1}</div>)}
        </div>
      </section>

      <!-- 7. Components (v2 tokens; full restyle in 4e) -->
      <section class="section" aria-labelledby="comp-h">
        <h2 id="comp-h">7 · Components</h2>
        <p class="note" style="margin-top: var(--space-2);">
          Rendered under v2 tokens. The full component restyle (hairlines, Geist labels,
          de-uppercasing) lands in Phase 4e — what you see here is the token swap only.
        </p>

        <h3 style="margin-top: var(--space-5);">Buttons</h3>
        <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-3);">
          <Button>Register</Button>
          <Button variant="secondary">Read the case</Button>
          <Button variant="ghost">Cancel</Button>
          <Button disabled>Submitting…</Button>
          <Button href="https://conference.iemss.org/streams/" external>iEMSs program</Button>
        </div>

        <h3 style="margin-top: var(--space-6);">Links</h3>
        <p>
          In prose, the dataset citation reads <Link href="/data/">curated input data</Link> for
          the coastal Bangladesh case. External references like
          <Link href="https://cpree.princeton.edu/news/2024/researchers-around-world-attend-climate-migration-workshop-princeton">Princeton C-PREE</Link>
          carry an unobtrusive glyph.
        </p>

        <h3 style="margin-top: var(--space-6);">Cards — surface steps deeper, not white</h3>
        <div class="swatch-grid" style="margin-top: var(--space-3);">
          <Card>
            <p class="section-label" style="margin: 0 0 var(--space-2);">Dataset</p>
            <h4 style="margin: 0 0 var(--space-2);">GHSL population density</h4>
            <p class="note" style="margin: 0;">Schiavina, Freire, MacManus (2019). 100 m – 1 km. CC BY 4.0.</p>
          </Card>
          <Card href="/outputs/">
            <p class="section-label" style="margin: 0 0 var(--space-2);">Webinar</p>
            <h4 style="margin: 0 0 var(--space-2);">February Webinar Presentation</h4>
            <p class="note" style="margin: 0;">Watch recording ↗</p>
          </Card>
        </div>

        <h3 style="margin-top: var(--space-6);">Callouts</h3>
        <div style="display: grid; gap: var(--space-3); margin-top: var(--space-3);">
          <Callout variant="note" label="The shared question">
            Net internal migration in coastal Bangladesh districts, 2025–2050, under SSP2-4.5.
          </Callout>
          <Callout variant="caution" label="Empty state">
            Working papers from participating teams will appear here as they are released.
          </Callout>
        </div>

        <h3 style="margin-top: var(--space-6);">Citation block</h3>
        <CitationBlock
          authors="Bell, A. R., Wrathall, D. J., Mueller, V., Chen, J., Oppenheimer, M., et al."
          year={2021}
          title="Migration towards Bangladesh coastlines projected to increase with sea-level rise through 2100"
          venue="Environmental Research Letters"
          reference="16(2), 024045"
          doi="10.1088/1748-9326/abdc5b"
        />

        <h3 style="margin-top: var(--space-6);">Form inputs</h3>
        <form aria-label="Form preview" style="max-width: 32rem;">
          <FormField id="name" name="name" label="Name" required placeholder="First and last" />
          <FormField id="broken" name="broken" label="Field with error (preview)" error="This field is required." />
          <Button type="submit">Submit registration</Button>
        </form>
      </section>

      <!-- 8. Signature visualization -->
      <section class="section" aria-labelledby="viz-h">
        <h2 id="viz-h">8 · Signature visualization</h2>
        <p class="note" style="margin-top: var(--space-2);">
          Atlas-plate build (Phase 2c) mounted on the plate token (V8) — the figure reads
          as a warm print on the white gallery wall. Check that 05-smooth vs 06-discrete
          reads at a glance, and that panel 04's emptiness reads as "aggregated," not
          "unfinished." The kinetic version (Phase 2d) animates this same geometry.
        </p>
        <div class="plate" style="margin-top: var(--space-4);">
          <SignatureViz />
        </div>
      </section>

      <!-- 9. Motion system (V9) -->
      <section class="section" aria-labelledby="motion-h">
        <h2 id="motion-h">9 · Motion</h2>
        <p class="note" style="margin-top: var(--space-2);">
          Motion explains or orients; it never decorates. Everything honors reduced motion
          by rendering the static end state. JS budget for the whole system including the
          Phase 2d kinetic figure: ≤3KB, vanilla, no libraries. The demos below are live —
          reload the page to replay the reveals.
        </p>

        <h3 style="margin-top: var(--space-5);">Scroll-reveal (300ms fade + 4px rise, once)</h3>
        <div class="reveal" style="margin-top: var(--space-3); max-width: 36rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-4);">
          <p style="margin: 0;">
            This block faded in and rose 4px when it entered the viewport. Without
            JavaScript it would simply have been visible from the start; under reduced
            motion it renders immediately in its end state.
          </p>
        </div>

        <h3 style="margin-top: var(--space-6);">Hairline draw-in (scaleX, 400ms)</h3>
        <hr class="reveal-rule" style="margin-block: var(--space-3); max-width: 36rem;" />
        <p class="section-label reveal" style="margin: 0;">Sec. 09 / Motion</p>

        <h3 style="margin-top: var(--space-6);">Underline slide (150ms, hover)</h3>
        <p style="margin-top: var(--space-3);">
          <a href="/outputs/" class="underline-slide" style="font-family: var(--font-sans); color: var(--color-ink); font-weight: 500;">Hover this standalone link</a>
          <span class="note" style="margin-left: var(--space-3);">— in-prose links keep their persistent underline (WCAG 1.4.1).</span>
        </p>

        <h3 style="margin-top: var(--space-6);">Hero ambience (Tier 2 — zero JS)</h3>
        <p class="note" style="margin-top: var(--space-2);">
          14 terracotta dots, 2–4px, opacity 0.15–0.35, drifting southwest↔northeast on
          60–90s loops — the ambience quotes the coastal-to-Dhaka direction. Gone entirely
          under reduced motion. If you have to look for it, it's working.
        </p>
        <div style="position: relative; height: 220px; margin-top: var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden;">
          <HeroAmbience />
          <p style="position: relative; padding: var(--space-5); max-width: 28rem; margin: 0; color: var(--color-ink-muted); font-size: var(--text-small);">
            Placeholder hero copy — the dots drift behind content at the pace of a
            slow tide. A reader who never notices them loses nothing.
          </p>
        </div>
      </section>
    </main>

    <footer class="container" style="padding-block: var(--space-6);">
      <p class="note">Internal design system · excluded from sitemap · noindex.</p>
    </footer>
    <RevealScript />
  </body>
</html>
