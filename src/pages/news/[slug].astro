---
/**
 * News full post — src/pages/news/[slug].astro
 *
 * Generates a page only for news entries with `fullPost: true` in frontmatter.
 * The Markdown body becomes the post body. Entries without fullPost are
 * excerpt-only on the /news/ index and have no detail page.
 *
 * In v1 no seed entry sets fullPost, so this route generates zero pages —
 * which is correct. It exists so a maintainer can flip fullPost: true on a
 * future entry and get a detail page with no code changes.
 */
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const entries = await getCollection("news");
  return entries
    .filter((e) => e.data.fullPost)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

// Explicit prop typing: when the collection is empty, getStaticPaths returns
// [] and Astro can't infer the props shape, so we name it directly.
const { entry } = Astro.props as { entry: CollectionEntry<"news"> };
const { Content } = await render(entry);

function longDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  datePublished: entry.data.date.toISOString().slice(0, 10),
  description: entry.data.excerpt,
  author: { "@type": "Organization", name: "3MIP" },
};
---

<Base title={entry.data.title} description={entry.data.excerpt} jsonLd={jsonLd}>
  <article class="post">
    <p class="post__back"><a href="/news/">← All news</a></p>
    <time datetime={entry.data.date.toISOString().slice(0, 10)} class="post__date">
      {longDate(entry.data.date)}
    </time>
    <h1>{entry.data.title}</h1>
    {entry.data.tags && entry.data.tags.length > 0 && (
      <ul class="post__tags" aria-label="Tags">
        {entry.data.tags.map((t) => <li>{t}</li>)}
      </ul>
    )}
    <div class="post__body prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .post {
    max-width: 42rem;
    margin: 0 auto;
    padding: var(--space-7) var(--space-3) var(--space-8);
  }
  @media (min-width: 768px) { .post { padding: var(--space-8) var(--space-5); } }
  .post__back { margin: 0 0 var(--space-4); }
  .post__back a { color: var(--color-ink-muted); text-decoration: none; font-size: var(--text-small); }
  .post__back a:hover { color: var(--color-accent); text-decoration: underline; }
  .post__date { font-size: var(--text-small); color: var(--color-ink-muted); font-weight: 500; }
  .post h1 { margin: var(--space-2) 0 var(--space-3); }
  .post__tags {
    list-style: none; margin: 0 0 var(--space-5); padding: 0;
    display: flex; gap: var(--space-2); flex-wrap: wrap;
  }
  .post__tags li {
    font-size: var(--text-caption); color: var(--color-ink-subtle);
    text-transform: uppercase; letter-spacing: 0.06em;
    border: 1px solid var(--color-border); border-radius: var(--radius); padding: 2px var(--space-2);
  }
  .post__body { margin-top: var(--space-4); }
  .post__body :global(p) { margin: 0 0 var(--space-3); max-width: 65ch; }
  .post__body :global(h2) { margin: var(--space-5) 0 var(--space-3); }
</style>
