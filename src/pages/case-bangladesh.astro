---
/**
 * Case 1: Coastal Bangladesh — src/pages/case-bangladesh.astro
 *
 * Per docs/CONTENT-INVENTORY.md § Case 1. Seven content sections.
 */
import Base from "../layouts/Base.astro";
import Link from "../components/Link.astro";
import Callout from "../components/Callout.astro";
import CitationBlock from "../components/CitationBlock.astro";
import BangladeshMap from "../components/BangladeshMap.astro";
import TimelineList from "../components/TimelineList.astro";
import DataCategoryCard from "../components/DataCategoryCard.astro";
import ModelArchetypeCard from "../components/ModelArchetypeCard.astro";
import "../styles/editorial.css";

// The 16 datasets group into three families, each with a fixed color identity
// reused on the Data page. Counts mirror data.astro (7 / 5 / 4 = 16).
const DATA_FAMILIES = [
  { name: "Population & socioeconomic", count: 7, color: "var(--accent-ochre)", href: "/data/#pop-h", seed: 7, description: "Population grids, household surveys, income, and education." },
  { name: "Environmental", count: 5, color: "var(--accent-teal)", href: "/data/#env-h", seed: 5, description: "Inundation, flood extent, soil salinity, and rainfall." },
  { name: "Mobility", count: 4, color: "var(--color-accent)", href: "/data/#mob-h", seed: 4, description: "Modeled migration flows and observed displacement." },
];

// The six model families in the signature figure, with plain-language glosses.
const ARCHETYPES = [
  { kind: "abm" as const, name: "Agent-based", gloss: "Simulates individual households deciding whether, when, and where to move." },
  { kind: "gravity" as const, name: "Gravity", gloss: "Predicts flows between places from their populations and the distance between them." },
  { kind: "radiation" as const, name: "Radiation", gloss: "Derives flows from the population lying between an origin and a destination — parameter-free." },
  { kind: "iam" as const, name: "Integrated assessment", gloss: "Embeds migration within a coupled model of climate, economy, and policy." },
  { kind: "ml" as const, name: "Machine learning", gloss: "Learns migration patterns statistically from observed data." },
  { kind: "cellular" as const, name: "Cellular automaton", gloss: "Evolves a grid of places by local transition rules at each time step." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ResearchProject",
  name: "3MIP Case 1: Coastal Bangladesh",
  description:
    "3MIP's first benchmark case provides a single curated input dataset for coastal Bangladesh. Each participating team brings its own model architecture and research question; the project synthesizes the resulting divergence.",
  location: { "@type": "Place", name: "Coastal Bangladesh" },
  parentOrganization: { "@type": "Organization", name: "3MIP", alternateName: "Mobility and Migration Modeling Intercomparison Project" },
};

// Official timeline, corrected in Phase 4D against the live site (the Weebly
// timeline's "Early November, 2026" is a typo for 2025).
const timelineItems = [
  {
    date: "2025-10-01",
    dateLabel: "October 1, 2025",
    text: "3MIP launches; registration opens.",
    kind: "done" as const,
  },
  {
    date: "2025-11",
    dateLabel: "Early November 2025",
    text: "First participant webinar.",
    kind: "done" as const,
  },
  {
    date: "2025-12",
    dateLabel: "December 2025 – May 2026",
    text: "Regular participant webinars; teams run their models and share preliminary findings.",
    kind: "active" as const,
  },
  {
    date: "2026-07-12",
    dateLabel: "July 12–16, 2026",
    text: "First synthesis at iEMSs 2026, University College Dublin (Session C7 + Workshop WSC7).",
    kind: "active" as const,
  },
  {
    date: "2026-08",
    dateLabel: "August – December 2026",
    text: "Regular webinars continue.",
    kind: "planned" as const,
  },
  {
    date: "2026-12",
    dateLabel: "Late 2026 onward",
    text: "Submissions to <em>Climatic Change</em> topical collection, received through 2027.",
    kind: "planned" as const,
  },
  {
    date: "2027",
    dateLabel: "2027",
    text: "Synthesis paper drafted from the collected outputs.",
    kind: "aspirational" as const,
  },
];

// Background literature (official Context page, Phase 4D). Bell et al. 2021
// also appears with full citation in the "Why Bangladesh" section above.
const READING_LIST = [
  {
    authors: "Bell, A. R., Wrathall, D. J., Mueller, V., Chen, J., Oppenheimer, M., et al.",
    year: 2021,
    title: "Migration towards Bangladesh coastlines projected to increase with sea-level rise through 2100",
    venue: "Environmental Research Letters",
    reference: "16(2), 024045",
    doi: "10.1088/1748-9326/abdc5b",
  },
  {
    authors: "Carrico, A. R., & Donato, K.",
    year: 2019,
    title: "Extreme weather and migration: evidence from Bangladesh",
    venue: "Population and Environment",
    reference: "41(1), 1–31",
    doi: "10.1007/s11111-019-00322-9",
  },
  {
    authors: "Chen, J., & Mueller, V.",
    year: 2018,
    title: "Coastal climate change, soil salinity and human migration in Bangladesh",
    venue: "Nature Climate Change",
    reference: "8, 981–985",
    doi: "10.1038/s41558-018-0313-8",
  },
  {
    authors: "Hassani-Mahmooei, B., & Parris, B. W.",
    year: 2012,
    title: "Climate change and internal migration patterns in Bangladesh: an agent-based model",
    venue: "Environment and Development Economics",
    reference: "17(6), 763–780",
    doi: "10.1017/S1355770X12000290",
  },
  {
    authors: "Mallick, B., Best, K., Carrico, A. R., Ghosh, T., Priodarshini, R., Sultana, Z., & Samanta, G.",
    year: 2023,
    title: "How do migration decisions and drivers differ against extreme environmental events?",
    venue: "Environmental Hazards",
    reference: "22(5), 475–497",
    doi: "10.1080/17477891.2023.2195152",
  },
];
---

<Base
  title="Case 1: Coastal Bangladesh"
  description="Coastal Bangladesh is 3MIP's first benchmark case. 175.7M people, sea-level rise, salinity, flood dynamics. One curated dataset; each team brings its own research question and model."
  jsonLd={jsonLd}
>
  <article class="page page-editorial">
    <header class="page__header">
      <h1>Case 1: Coastal Bangladesh</h1>
      <p class="lede">
        Bangladesh's coastal zone faces one of the most studied combinations
        of climate stress and population pressure in the world. For 3MIP's
        first benchmark case, participating teams work from a single curated
        dataset for coastal Bangladesh — each team choosing its own research
        question, model architecture, key variables, and outputs.
      </p>
    </header>

    <section class="reveal" aria-labelledby="why-h">
      <p class="kicker">Why Bangladesh</p>
      <h2 id="why-h">Why Bangladesh is the first case</h2>
      <p class="dropcap">
        Three factors converge on Bangladesh. The empirical literature on
        internal migration there is among the densest in the climate-migration
        field, providing a real benchmark against which model outputs can be
        sanity-checked. The country's population of 175.7 million (UNFPA SWOP
        2025) and its low-lying delta geography make the policy stakes
        consequential. And the data infrastructure — population grids, modeled
        migration flows, salinity layers, flood histories — is already openly
        licensed and usable.
      </p>
      <p>
        The coastal districts face coastal erosion, sea-level rise, seasonal
        monsoons, tropical cyclones, and salinity encroachment — and their
        populations are highly mobile. The case was chosen for data
        availability and the depth of the existing literature, not because
        the dynamics are simple.
      </p>
      <p>
        Bell et al. (2021) projected that migration <em>toward</em> Bangladesh's
        coast, not away from it, will continue through 2100 across the
        sea-level rise scenarios they studied. That finding sits in productive
        tension with the popular narrative of mass climate exodus and provides
        the empirical motivation for revisiting the problem with multiple
        model architectures.
      </p>

      <blockquote class="pullquote">
        Migration toward Bangladesh's coast — not away from it — is projected
        to continue through 2100.
        <cite>— Bell et al. (2021), Environmental Research Letters</cite>
      </blockquote>

      <CitationBlock
        authors="Bell, A. R., Wrathall, D. J., Mueller, V., Chen, J., Oppenheimer, M., et al."
        year={2021}
        title="Migration towards Bangladesh coastlines projected to increase with sea-level rise through 2100"
        venue="Environmental Research Letters"
        reference="16(2), 024045"
        doi="10.1088/1748-9326/abdc5b"
      />
    </section>

    <section class="reveal editorial-band editorial-band--parchment" aria-labelledby="q-h">
      <p class="kicker">The benchmark</p>
      <h2 id="q-h">The benchmark design</h2>
      <Callout variant="note" label="The benchmark design">
        <strong>3MIP fixes the allowable data inputs — a single curated dataset
        for coastal Bangladesh — and leaves everything downstream to each
        team.</strong>
        The research question, model design, key variables, dynamics, and
        outputs are all at the modeler's discretion. Input data is held
        constant; what each team asks of it, and how, is not.
      </Callout>
      <p>
        Teams choose how to define and model migration within their own
        architecture. The intercomparison does not require harmonized output
        variables; it requires only harmonized inputs. Where outputs diverge —
        and they will — the synthesis documents the divergence and the
        methodological choices that drive it.
      </p>
    </section>

    <section class="reveal" aria-labelledby="arch-h">
      <p class="kicker">Model architectures</p>
      <h2 id="arch-h">The six model architectures</h2>
      <p>
        The signature figure on the home page renders the same curated dataset
        through six families of migration model. Each encodes how people move
        differently — which is exactly why their outputs diverge.
      </p>
      <div class="arch-grid">
        {ARCHETYPES.map((a) => (
          <ModelArchetypeCard kind={a.kind} name={a.name} gloss={a.gloss} />
        ))}
      </div>
    </section>

    <section class="reveal" aria-labelledby="geo-h">
      <h2 id="geo-h">Geographic scope</h2>
      <div class="geo">
        <div>
          <p>
            The case centers on the Ganges-Brahmaputra-Meghna delta and
            Bangladesh's low-lying coastal zone along the Bay of Bengal. The
            curated dataset covers the country at the resolutions documented on
            the Data page; 3MIP does not prescribe a fixed list of study
            districts, so the spatial scope of any analysis is the team's own
            choice.
          </p>
        </div>
        {/* The map mounts on the plate token (V8): a warm print on the wall. */}
        <div class="plate">
          <BangladeshMap />
        </div>
      </div>
    </section>

    <section class="reveal editorial-band editorial-band--teal" aria-labelledby="data-h">
      <h2 id="data-h">Curated input dataset</h2>
      <p>
        3MIP curates 16 datasets for the case — population and socioeconomic,
        environmental, and mobility data — documented with citations and
        access links on the Data page. Teams use this curation as their common
        input. The data list may be expanded, but any new dataset must be made
        known and available to all teams; contact project coordination to
        request the inclusion of an additional dataset.
      </p>
      <div class="data-families">
        {DATA_FAMILIES.map((f) => (
          <DataCategoryCard
            name={f.name}
            count={f.count}
            description={f.description}
            color={f.color}
            href={f.href}
            seed={f.seed}
          />
        ))}
      </div>
      <p>
        <Link href="/data/" variant="in-prose">See the full data documentation</Link>.
      </p>
    </section>

    <section class="reveal" aria-labelledby="time-h">
      <h2 id="time-h">Expected outputs and timeline</h2>
      <TimelineList items={timelineItems} />
    </section>

    <section class="reveal editorial-band editorial-band--parchment" aria-labelledby="lit-h">
      <p class="kicker">Background literature</p>
      <h2 id="lit-h">Background literature</h2>
      <p>
        The papers below frame the Bangladesh case. Bell et al. (2021)
        provides the direct empirical motivation; the others document the
        migration dynamics the participating models must contend with.
      </p>
      {READING_LIST.map((paper) => (
        <CitationBlock
          authors={paper.authors}
          year={paper.year}
          title={paper.title}
          venue={paper.venue}
          reference={paper.reference}
          doi={paper.doi}
        />
      ))}
    </section>

    <section class="reveal editorial-band editorial-band--teal" aria-labelledby="guide-h">
      <h2 id="guide-h">Participation guidelines</h2>
      <p>
        3MIP runs on a small set of shared commitments rather than a formal
        written protocol:
      </p>
      <ul class="guidelines">
        <li><strong>Register</strong> as a modeler or a domain expert.</li>
        <li><strong>The data inputs are fixed.</strong> Every team works from
          the same curated dataset for coastal Bangladesh.</li>
        <li><strong>The research question is open.</strong> Model design, key
          variables, dynamics, and outputs are each team's own choice.</li>
        <li><strong>The dataset list can grow</strong> — but only when a new
          dataset is made known and available to all teams.</li>
        <li><strong>Regular meetings</strong> are held with times rotated across
          time zones, so the inconvenience of out-of-hours meetings is shared.</li>
        <li><strong>Code and findings are shared</strong> with the network.</li>
      </ul>
      <p>
        <Link href="/participate/" variant="in-prose">Register to take part</Link>.
      </p>
    </section>
  </article>
</Base>

<style>
  .page {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--space-7) var(--space-3) var(--space-8);
  }
  @media (min-width: 768px) {
    .page { padding: var(--space-8) var(--space-5); }
  }
  .page__header { margin-bottom: var(--space-7); }
  .page__header h1 { margin: 0; }
  .lede {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg--line-height);
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
    max-width: 60ch;
  }
  .page section { margin-top: var(--space-7); }
  .page h2 { margin: 0 0 var(--space-3); }
  .page p { margin: 0 0 var(--space-3); max-width: 65ch; }
  .page p:last-child { margin-bottom: 0; }

  .geo {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: start;
    margin-top: var(--space-3);
  }
  @media (min-width: 768px) {
    .geo {
      grid-template-columns: 3fr 2fr;
      gap: var(--space-5);
    }
  }
  .geo p { margin: 0; }

  .guidelines {
    margin: var(--space-3) 0 0;
    padding-left: var(--space-4);
    color: var(--color-ink-muted);
    max-width: 65ch;
  }
  .guidelines li { margin-bottom: var(--space-2); padding-left: var(--space-1); }
  .guidelines li strong { color: var(--color-ink); }

  .data-families {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin: var(--space-4) 0;
  }
  @media (min-width: 640px) {
    .data-families { grid-template-columns: repeat(3, 1fr); }
  }

  .arch-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
  @media (min-width: 600px) { .arch-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .arch-grid { grid-template-columns: repeat(3, 1fr); } }

  .verify {
    color: var(--color-accent-deep);
    font-size: var(--text-caption);
    font-weight: 500;
  }
  .pending {
    color: var(--color-accent-deep);
    font-size: var(--text-caption);
    font-weight: 500;
  }
  .pending-note {
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
</style>
