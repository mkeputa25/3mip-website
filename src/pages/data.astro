const ALL_ROWS = [...POPULATION_ROWS, ...ENVIRONMENTAL_ROWS, ...MOBILITY_ROWS];

const datasetJsonLd = {
  "@context": "https://schema.org",
  "@graph": ALL_ROWS.map((r) => ({
    "@type": "Dataset",
    name: r.dataset,
    description: r.citation,
    variableMeasured: r.variable,
    ...(r.license !== "—" ? { license: r.license } : {}),
    ...(r.link ? { url: r.link.href } : {}),
  })),
};
---

<Base
  title="Data"
  description="16 curated datasets for 3MIP's Bangladesh case: population, socioeconomic, environmental, and mobility data with citations and access links."
  jsonLd={datasetJsonLd}
>
  <article class="page">
    <header class="page__header">
      <h1>Curated input data</h1>
      <p class="lede">
        3MIP curates input data for the Bangladesh case — 16 datasets across
        three groups: population and socioeconomic, environmental, and
        mobility. Each dataset is documented with its variable, coverage,
        resolution, citation, and access link. Teams use this curation as
        their common input.
      </p>
    </header>

    <section class="reveal" aria-labelledby="cite-h">
      <h2 id="cite-h" class="vh">Citation and extension policy</h2>
      <Callout variant="note" label="How to cite the 3MIP curated dataset">
        When using these datasets through the 3MIP curation, cite both the
        original publication of each dataset (listed below) and the 3MIP
        curated package:
        <em>Bell, Best, Tierolf &amp; the 3MIP Consortium (2025). 3MIP Curated
        Input Dataset for Coastal Bangladesh, Version 1.0.</em>
        [DOI when minted]
      </Callout>

      <Callout variant="note" label="Extending the data list" class="mt-4">
        This data list may be expanded, but any new dataset must be made known
        and available to all teams.
        <a href="/contact/">Contact project coordination</a> to request the
        inclusion of an additional dataset.
      </Callout>
    </section>

    <section class="reveal" aria-labelledby="pop-h">
      <h2 id="pop-h">Population and socioeconomic data</h2>
      <DataTable rows={POPULATION_ROWS} caption="Population and socioeconomic datasets curated for the Bangladesh case." />
    </section>

    <section class="reveal" aria-labelledby="env-h">
      <h2 id="env-h">Environmental data</h2>
      <DataTable rows={ENVIRONMENTAL_ROWS} caption="Environmental datasets curated for the Bangladesh case." />
    </section>

    <section class="reveal" aria-labelledby="mob-h">
      <h2 id="mob-h">Mobility data</h2>
      <DataTable rows={MOBILITY_ROWS} caption="Mobility datasets curated for the Bangladesh case." />
    </section>
  </article>
</Base>

<style>
  .page {
    max-width: 72rem;
    margin: 0 auto;
    padding: var(--space-7) var(--space-3) var(--space-8);
  }
  @media (min-width: 768px) {
    .page { padding: var(--space-8) var(--space-5); }
  }
  .page__header { margin-bottom: var(--space-6); max-width: 60ch; }
  .page__header h1 { margin: 0; }
  .lede {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg--line-height);
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
  .page section { margin-top: var(--space-7); }
  .page section:first-of-type { margin-top: var(--space-5); }
  .page h2 { margin: 0 0 var(--space-3); }

  .pending {
    color: var(--color-warning);
    font-size: var(--text-caption);
    font-weight: 500;
  }
  :global(.mt-4) { margin-top: var(--space-4); }
</style>
