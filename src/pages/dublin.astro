---
/**
 * /dublin — QR-code landing page for iEMSs 2026 (Phase 4D.7, restyled 4e).
 *
 * One screen-and-a-half: what 3MIP is in 90 seconds, the sessions, the
 * kinetic figure on a full-bleed plate band, one CTA. Excluded from the
 * primary nav; linked from the Home milestone block and Outputs.
 */
import Base from "../layouts/Base.astro";
import SignatureViz from "../components/SignatureViz.astro";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: "3MIP at iEMSs 2026 — Session C7 and Workshop WSC7",
  startDate: "2026-07-12",
  endDate: "2026-07-16",
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: "University College Dublin",
    address: { "@type": "PostalAddress", addressLocality: "Dublin", addressCountry: "IE" },
  },
  organizer: {
    "@type": "Organization",
    name: "International Environmental Modelling and Software Society (iEMSs)",
    url: "https://conference.iemss.org/",
  },
  about: {
    "@type": "Organization",
    name: "Mobility and Migration Modeling Intercomparison Project",
    alternateName: "3MIP",
    url: "https://3mip-project.com",
  },
};
---

<Base
  title="3MIP at iEMSs 2026"
  description="3MIP at iEMSs 2026 Dublin: Session C7 and Workshop WSC7. The climate-migration model intercomparison in 90 seconds, and how to join."
  jsonLd={jsonLd}
>
  <article>
    <header class="page-narrow">
      <p class="eyebrow">iEMSs 2026 · University College Dublin · July 12–16, 2026</p>
      <h1>3MIP in 90 seconds</h1>
      <p class="lede">
        3MIP — the Mobility and Migration Modeling Intercomparison Project —
        is a community of researchers who apply their climate-migration models
        to a shared benchmark case. The first case is coastal Bangladesh.
      </p>
      <ul class="facts">
        <li>Launched October 2025, modeled on AgMIP and ISIMIP. Founded at a Princeton C-PREE workshop in 2024.</li>
        <li>Led from Cornell (Bell), Ohio State (Best), and VU Amsterdam (Tierolf).</li>
        <li>Registration is open and free — 16 curated datasets, shared question, your model stays yours.</li>
      </ul>
    </header>

    <section class="page-narrow reveal" aria-labelledby="sessions-h">
      <h2 id="sessions-h">Find us at the conference</h2>
      <div class="sessions">
        <p>
          <strong>Session C7</strong> — <em>Mobility and Migration Modeling
          Intercomparison Project (3MIP) – An open, first synthesis</em>
        </p>
        <p>
          <strong>Workshop WSC7</strong> — <em>Panel Discussion – 3MIP</em>
        </p>
        <p class="sessions__note">
          Day and room: to be announced when the iEMSs 2026 preliminary
          program is published (15 June 2026).
          Check the <Link href="https://conference.iemss.org/streams/" variant="external">iEMSs program</Link>.
        </p>
      </div>
    </section>

    <!-- Full-bleed plate band (4e) — the figure as a warm print. -->
    <section class="viz-band reveal" aria-labelledby="viz-h">
      <div class="viz-band__inner">
        <h2 id="viz-h">The pitch in one figure</h2>
        <SignatureViz idBase="dublin-viz" class="viz-band__fig" />
        <p class="viz-alt">
          Six model architectures, the same Bangladesh outline, the same
          question — six different visual grammars: household dots, flow arcs,
          catchment rings, flat regional polygons, smooth contours, discrete
          cells. When animated, each panel moves in its own model's logic
          across a repeating 2025–2050 loop — drifting agents, drawing and
          pulsing flows, rippling catchments, jumping time-steps, crossfading
          surfaces, ticking generations. A pause control stops the loop; with
          reduced motion the figure is static. 3MIP exists to make that
          divergence legible and synthesize it.
        </p>
      </div>
    </section>

    <section class="page-narrow join reveal" aria-labelledby="join-h">
      <h2 id="join-h" class="vh">Join</h2>
      <Button href="/participate/">Register to participate</Button>
      <p class="join__more">
        Webinar recordings and conference materials are on the
        <Link href="/outputs/" variant="in-prose">Outputs</Link> page.
      </p>
    </section>
  </article>
</Base>

<style>
  .page-narrow {
    max-width: 45rem;
    margin: 0 auto;
    padding: var(--space-6) var(--space-3) 0;
  }
  @media (min-width: 768px) { .page-narrow { padding: var(--space-7) var(--space-5) 0; } }

  header.page-narrow h1 { margin: 0; }
  .lede {
    font-size: var(--text-body-lg);
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
    max-width: 60ch;
  }
  .eyebrow { margin: 0 0 var(--space-2); }
  .facts {
    margin: var(--space-4) 0 0;
    padding-left: var(--space-4);
    list-style-type: square;
    color: var(--color-ink-muted);
  }
  .facts li { padding-block: var(--space-1); max-width: 60ch; }

  section.page-narrow { padding-top: var(--space-6); }
  h2 { margin: 0 0 var(--space-3); }

  .sessions {
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
    padding: var(--space-4);
    background: var(--color-surface);
  }
  .sessions p { margin: 0 0 var(--space-2); max-width: 65ch; }
  .sessions p:last-child { margin-bottom: 0; }
  .sessions__note { font-family: var(--font-sans); color: var(--color-ink-muted); font-size: var(--text-small); }

  /* Full-bleed plate band — parchment edge-to-edge, space-8 breathing. */
  .viz-band {
    background: var(--color-plate);
    margin-block: var(--space-8);
    padding-block: var(--space-7);
  }
  .viz-band__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding-inline: var(--space-3);
  }
  @media (min-width: 768px) { .viz-band__inner { padding-inline: var(--space-5); } }
  .viz-band__fig { margin-top: var(--space-5); }
  .viz-alt {
    margin-top: var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    max-width: 65ch;
  }

  .join {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    padding-bottom: var(--space-7);
  }
  .join__more {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
  }
</style>
