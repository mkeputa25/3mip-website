---
/**
 * Home — src/pages/index.astro
 *
 * Per docs/CONTENT-INVENTORY.md § Home, amended in Phases 4D and 4e.
 * Ten sections:
 *   1. Header (shared via Base)
 *   2. Hero — oversized Fraunces display, ambience field in the right third
 *   3. Signature visualization — FULL-BLEED parchment plate band: the
 *      boldest compositional moment on the site (4e)
 *   4. Current case (2-col text + key facts)
 *   5. Next milestone (iEMSs 2026 — July 12–16, UC Dublin)
 *   6. How 3MIP works — hairline-ruled text blocks, hanging Fraunces
 *      numerals; deliberately NOT a SaaS feature grid (V4)
 *   7. Leadership (cards from the team collection + coordination line)
 *   8. Registration CTA
 *   9. Lineage strip
 *  10. Footer (shared via Base)
 *
 * Scroll-reveal applies to sections below the fold; the hero never waits
 * for a reveal (V9). Headline + tagline [PENDING BELL APPROVAL].
 */
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import SignatureViz from "../components/SignatureViz.astro";
import HeroAmbience from "../components/HeroAmbience.astro";
import SectionDivider from "../components/SectionDivider.astro";
import Button from "../components/Button.astro";
import Link from "../components/Link.astro";

// Leadership section is driven by the team collection so a successor swaps a
// Markdown file, not this page. Co-leads alphabetical by surname.
const team = await getCollection("team");
const coLeads = team
  .filter((e) => e.data.role === "co-lead")
  .sort((a, b) => a.data.surname.localeCompare(b.data.surname));
// Coordination line: active coordinator first (primary contact).
// NOTE: this contact line must be updated when project coordination
// transitions after June 2026 — edit src/content/team/, not this file.
const coordinators = team
  .filter((e) => e.data.role === "project-management")
  .sort((a, b) => {
    const aCoord = (a.data.shortRole ?? "").toLowerCase().includes("coordinator") ? 0 : 1;
    const bCoord = (b.data.shortRole ?? "").toLowerCase().includes("coordinator") ? 0 : 1;
    return aCoord - bCoord || a.data.surname.localeCompare(b.data.surname);
  });

const WORKS_STEPS = [
  {
    h: "Register",
    p: "Tell us your modeling approach and research interest.",
  },
  {
    h: "Receive curated data",
    p: "Get access to the harmonized Bangladesh input dataset.",
  },
  {
    h: "Run your model",
    p: "Apply your approach to the shared question. Your model stays yours.",
  },
  {
    h: "Contribute to synthesis",
    p: "Submit outputs to the Climatic Change topical collection and present at iEMSs.",
  },
];

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Mobility and Migration Modeling Intercomparison Project",
  alternateName: "3MIP",
  description:
    "3MIP coordinates climate-migration modelers around shared benchmark cases. The first case is coastal Bangladesh.",
  founder: [
    { "@type": "Person", name: "Andrew Reid Bell", affiliation: "Cornell University" },
    { "@type": "Person", name: "Kelsea Best", affiliation: "The Ohio State University" },
    { "@type": "Person", name: "Lars Tierolf", affiliation: "Vrije Universiteit Amsterdam" },
  ],
  foundingDate: "2025-10",
  url: "https://3mip-project.com",
  sameAs: ["https://conference.iemss.org/streams/"],
};
---

<Base
  title="3MIP — Mobility and Migration Modeling Intercomparison Project"
  bareTitle
  description="3MIP coordinates climate-migration modelers around shared benchmark cases. First case: coastal Bangladesh. Synthesis at iEMSs Dublin, July 2026."
  jsonLd={orgJsonLd}
>
  <!-- Section 2 — Hero (never waits for a reveal). -->
  <section class="hero" aria-labelledby="hero-h">
    <div class="hero__ambience" aria-hidden="true">
      <HeroAmbience />
    </div>
    <div class="hero__inner">
      <h1 id="hero-h" class="hero__headline">
        Different models. Same question. One coordinated answer.
      </h1>
      <p class="hero__subhead">
        3MIP is a community of researchers who apply their climate-migration
        models to a shared benchmark case. The first case is coastal Bangladesh.
      </p>
    </div>
  </section>

  <!-- Section 3 — Signature visualization: full-bleed plate band. -->
  <section class="viz-band reveal" aria-labelledby="sigviz-h">
    <div class="viz-band__inner">
      <h2 id="sigviz-h">Why the same question yields different answers</h2>
      <p class="lede">
        Different model architectures — agent-based, gravity, radiation,
        integrated assessment, and machine learning — encode different
        assumptions about how people decide to move. Run the same Bangladesh
        migration question through each and you get different answers.
        3MIP makes that divergence visible and synthesizes it.
      </p>

      <SignatureViz class="viz-band__fig" />

      <p class="long-alt">
        <strong>Long-form text alternative.</strong>
        Each of the six panels above shows the same stylized outline of
        Bangladesh, but drawn in the visual grammar of a different model
        architecture. Agent-based: about twenty individual dots of varying
        size — household clusters — denser along the southwest coast and the
        corridor toward Dhaka. Gravity: flow arcs of varying thickness from
        five coastal origin points to three destination cities; thicker arcs
        are larger flows. Radiation: nested rings spreading from one focal
        point, spacing widening and color fading outward. Integrated
        assessment: five regional polygons each filled with a single flat
        value — no interior detail, because the model aggregates. Machine
        learning: smooth nested contour bands deepening toward a coastal
        core, with no hard edges. Cellular automaton: a coarse grid of
        discrete colored cells. Panels share a sequential color ramp from
        low to high intensity, a scale bar, and the common research question.
        When animated, each panel moves in its own model's logic across a
        repeating 2025–2050 loop: the dots drift toward the corridor and a
        few relocate; the arcs draw in and pulse with flow weight; the rings
        ripple outward in sequence; the region fills jump between discrete
        time-step states; the contour surface crossfades between predicted
        states; and the cells change in discrete generations. A pause
        control stops the loop; with reduced motion enabled the figure is
        fully static.
      </p>
    </div>
  </section>

  <!-- Section 4 — Current case -->
  <section class="band reveal" aria-labelledby="case-h">
    <div class="band__inner">
      <SectionDivider num="02" name="The case" />
      <div class="case-grid">
        <div>
          <h2 id="case-h">Case 1: Coastal Bangladesh</h2>
          <p>
            Bangladesh has 175.7 million people, much of it living in a low-lying
            delta where sea-level rise, salinity, and flood dynamics interact
            with economic and social drivers of migration. Bell et al. (2021)
            projected continued migration toward Bangladesh's coast through 2100
            under all studied scenarios — not away from it. The empirical density
            and policy stakes make this the right place for a first benchmark.
          </p>
          <p>
            <Link href="/case-bangladesh/" variant="in-prose">Read the case in full</Link>.
          </p>
        </div>
        <aside class="case-facts" aria-label="Key facts about Case 1">
          <h3 class="case-facts__h">Key facts</h3>
          <dl>
            <div>
              <dt>Country population</dt>
              <dd>175.7 million <span class="case-facts__source">(UNFPA SWOP 2025)</span></dd>
            </div>
            <div>
              <dt>Time horizon</dt>
              <dd>2025–2050 baseline; extensions to 2100</dd>
            </div>
            <div>
              <dt>Climate scenarios</dt>
              <dd>
                SSP2-4.5 baseline; SSP1-2.6 and SSP5-8.5 sensitivity
              </dd>
            </div>
            <div>
              <dt>Curated dataset</dt>
              <dd>
                16 datasets — population, environmental, mobility (<Link href="/data/" variant="in-prose">Data page</Link>)
              </dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <!-- Section 5 — Next milestone -->
  <section class="band reveal" aria-labelledby="next-h">
    <div class="band__inner band__inner--narrow">
      <SectionDivider num="03" name="Next milestone" />
      <h2 id="next-h">Next milestone</h2>
      <div class="milestone">
        <p class="milestone__head"><strong>iEMSs 2026 — University College Dublin, July 12–16, 2026</strong></p>
        <p>
          Session C7: <em>Mobility and Migration Modeling Intercomparison
          Project (3MIP) – An open, first synthesis</em>
        </p>
        <p>
          Workshop WSC7: <em>Panel Discussion – 3MIP</em>
        </p>
        <p class="milestone__note">
          The first public synthesis of 3MIP results. Open to all conference
          attendees. Session day and room follow the preliminary program,
          which publishes June 15, 2026.
        </p>
        <p>
          <Link href="/dublin/" variant="in-prose">3MIP at iEMSs Dublin</Link>
          <span aria-hidden="true"> · </span>
          <Link href="https://conference.iemss.org/streams/" variant="external">
            Session details on the iEMSs program
          </Link>
        </p>
      </div>
    </div>
  </section>

  <!-- Section 6 — How 3MIP works: hairline-ruled blocks, hanging numerals.
       Deliberately not a SaaS feature grid (V4). -->
  <section class="band reveal" aria-labelledby="how-h">
    <div class="band__inner band__inner--narrow">
      <SectionDivider num="04" name="How it works" />
      <h2 id="how-h">How 3MIP works</h2>
      <ol class="works">
        {WORKS_STEPS.map((step, i) => (
          <li class="works__step">
            {i > 0 && <span class="works__rule reveal-rule" aria-hidden="true"></span>}
            <div class="works__row">
              <span class="works__num" aria-hidden="true">{i + 1}</span>
              <div class="works__body">
                <h3 class="works__h">{step.h}</h3>
                <p>{i === 3 ? <>Submit outputs to the <em>Climatic Change</em> topical collection and present at iEMSs.</> : step.p}</p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Section 7 — Leadership -->
  {coLeads.length > 0 && (
    <section class="band reveal" aria-labelledby="lead-h">
      <div class="band__inner">
        <SectionDivider num="05" name="Leadership" />
        <h2 id="lead-h">Leadership</h2>
        <ul class="leads">
          {coLeads.map((e) => (
            <li class="lead-card">
              <h3 class="lead-card__name">
                <a href="/team/" class="underline-slide">{e.data.name}</a>
              </h3>
              <p class="lead-card__affil">{e.data.affiliation}</p>
              <p class="lead-card__role">{e.data.shortRole}</p>
            </li>
          ))}
        </ul>
        {coordinators.length > 0 && (
          <p class="coord-line">
            Project coordination —
            {coordinators.map((c, i) => (
              <span>
                {" "}{c.data.name} ({c.data.affiliation}){c.data.email && (
                  <>, <a href={`mailto:${c.data.email}`}>{c.data.email}</a></>
                )}{i < coordinators.length - 1 ? " ·" : ""}
              </span>
            ))}
          </p>
        )}
      </div>
    </section>
  )}

  <!-- Section 8 — Registration CTA -->
  <section class="band band--cta reveal" aria-labelledby="cta-h">
    <div class="band__inner band__inner--narrow cta">
      <h2 id="cta-h" class="vh">Register</h2>
      <Button href="/participate/" class="cta__button">Register to participate</Button>
      <p class="cta__note">
        Open to climate-migration modelers using ABM, gravity, radiation,
        IAM, or ML approaches — and to domain experts on Bangladesh and
        climate-related mobility. No fee. Participation expectations on the
        Participate page.
      </p>
    </div>
  </section>

  <!-- Section 9 — Lineage strip -->
  <section class="lineage reveal" aria-label="Lineage and institutional context">
    <p>
      Inspired by AgMIP and ISIMIP. Founded at Princeton C-PREE, September 2024.
    </p>
  </section>
</Base>

<style>
  /* ── Shared band layout ─────────────────────────────────────────── */
  .band { padding-block: var(--space-7); }
  @media (min-width: 1024px) { .band { padding-block: var(--space-8) var(--space-7); } }
  .band--cta {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-7);
  }
  .band__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding-inline: var(--space-3);
  }
  @media (min-width: 768px) { .band__inner { padding-inline: var(--space-5); } }
  .band__inner--narrow {
    max-width: 48rem;
  }

  /* ── Hero — oversized, calm; ambience drifts in the right third. ── */
  .hero {
    position: relative;
    padding-block: var(--space-8) var(--space-7);
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .hero { padding-block: var(--space-9) var(--space-8); }
  }
  .hero__ambience {
    position: absolute;
    inset: 0 0 0 58%;
  }
  .hero__inner {
    position: relative;
    max-width: var(--content-max);
    margin: 0 auto;
    padding-inline: var(--space-3);
  }
  @media (min-width: 768px) {
    .hero__inner { padding-inline: var(--space-5); }
  }
  .hero__headline {
    font-family: var(--font-serif);
    font-variation-settings: var(--fraunces-display);
    font-weight: 500;
    font-size: clamp(2.5rem, 4.5vw + 1rem, 4.25rem);
    line-height: 1.04;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    text-wrap: balance;
    margin: 0;
    max-width: 18ch;
  }
  .hero__subhead {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg--line-height);
    color: var(--color-ink-muted);
    margin-top: var(--space-4);
    max-width: 38rem;
  }

  /* ── Section 3: full-bleed plate band — the boldest compositional
       moment on the site. Parchment edge-to-edge against the white
       page, space-8 breathing room above and below. ────────────────── */
  .viz-band {
    background: var(--color-plate);
    margin-block: var(--space-8);
    padding-block: var(--space-7);
  }
  @media (min-width: 1024px) {
    .viz-band { padding-block: var(--space-8); }
  }
  .viz-band__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding-inline: var(--space-3);
  }
  @media (min-width: 768px) {
    .viz-band__inner { padding-inline: var(--space-5); }
  }
  .viz-band__fig {
    margin-top: var(--space-6);
  }

  .lede {
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg--line-height);
    color: var(--color-ink);
    margin-top: var(--space-3);
    max-width: 60ch;
  }
  .long-alt {
    margin-top: var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    max-width: 65ch;
  }
  .long-alt strong { color: var(--color-ink); }

  /* ── Section 4: current case ───────────────────────────────────── */
  .case-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) {
    .case-grid {
      grid-template-columns: 3fr 2fr;
      gap: var(--space-7);
      align-items: start;
    }
  }
  .case-facts {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
  }
  .case-facts__h {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-label);
    color: var(--color-ink-muted);
    font-weight: 500;
    margin: 0 0 var(--space-3);
  }
  .case-facts dl { margin: 0; display: grid; gap: var(--space-3); }
  .case-facts dt { font-family: var(--font-sans); font-weight: 500; color: var(--color-ink); font-size: var(--text-small); }
  .case-facts dd { font-family: var(--font-sans); margin: var(--space-1) 0 0; color: var(--color-ink-muted); font-size: var(--text-small); }
  .case-facts__source { color: var(--color-ink-muted); font-size: var(--text-caption); }

  /* ── Section 5: next milestone ─────────────────────────────────── */
  .milestone {
    margin-top: var(--space-4);
    padding: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
  }
  .milestone p { margin: 0 0 var(--space-3); max-width: 60ch; }
  .milestone p:last-child { margin-bottom: 0; }
  .milestone__head { font-size: var(--text-body-lg); color: var(--color-ink); }
  .milestone__note { color: var(--color-ink-muted); font-style: italic; }

  /* ── Section 6: how it works — ruled blocks, hanging numerals ───── */
  .works {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
  }
  .works__rule {
    display: block;
    border-top: var(--hairline) solid var(--color-border-strong);
    margin-block: var(--space-5);
  }
  .works__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }
  @media (min-width: 768px) {
    .works__row {
      /* Numeral hangs in the left margin at desktop. */
      grid-template-columns: 5rem 1fr;
      gap: var(--space-4);
    }
  }
  .works__num {
    font-family: var(--font-serif);
    font-variation-settings: var(--fraunces-display);
    font-weight: 500;
    font-size: 3rem;
    line-height: 1;
    color: var(--color-accent-dim);
  }
  .works__h {
    font-size: var(--text-h4);
    margin: 0 0 var(--space-2);
  }
  .works__body p {
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 55ch;
  }

  /* ── Section 7: leadership ─────────────────────────────────────── */
  .leads {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) { .leads { grid-template-columns: repeat(3, 1fr); } }
  .lead-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
    background: var(--color-surface);
    transition: border-color 150ms var(--ease-out);
  }
  .lead-card:hover {
    border-color: var(--color-border-strong);
  }
  .lead-card__name {
    font-family: var(--font-serif);
    font-variation-settings: var(--fraunces-h3);
    font-size: var(--text-h4);
    font-weight: 500;
    margin: 0;
  }
  .lead-card__name a {
    color: var(--color-ink);
  }
  .lead-card__name a:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .lead-card__affil {
    font-family: var(--font-sans);
    margin: var(--space-2) 0 0;
    font-size: var(--text-small);
    color: var(--color-ink-muted);
  }
  .lead-card__role {
    font-family: var(--font-sans);
    margin: var(--space-2) 0 0;
    font-size: var(--text-small);
    font-style: italic;
    color: var(--color-ink-muted);
  }
  .coord-line {
    margin-top: var(--space-5);
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--color-border-strong);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    max-width: none;
  }
  .coord-line a { color: var(--color-ink); }

  /* ── Section 8: CTA ────────────────────────────────────────────── */
  .cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    text-align: center;
  }
  .cta__button { font-size: var(--text-body-lg); padding: var(--space-3) var(--space-5); }
  .cta__note {
    font-family: var(--font-sans);
    color: var(--color-ink-muted);
    font-size: var(--text-small);
    max-width: 40rem;
    margin: 0;
  }

  /* ── Section 9: lineage strip ──────────────────────────────────── */
  .lineage {
    padding-block: var(--space-7);
    text-align: center;
  }
  .lineage p {
    max-width: 60ch;
    margin: 0 auto;
    padding-inline: var(--space-3);
    font-size: var(--text-body-lg);
    font-style: italic;
    color: var(--color-ink-muted);
    line-height: 1.5;
  }
</style>
