---
/**
 * PersonCard — full leadership entry on the Team page.
 *
 * Per docs/CONTENT-INVENTORY.md § Team § Section 2: photo (optional, leads
 * only, pending Bell approval), name, affiliation, role-in-3MIP, bio
 * paragraph, selected publications, institutional link.
 *
 * The bio prose is passed as a slot (rendered from the markdown body of the
 * team collection entry) so a non-developer authors it as plain Markdown.
 * Publications + metadata come from frontmatter.
 */
interface Publication {
  citation: string;
  doi?: string;
}

interface Props {
  name: string;
  affiliation: string;
  shortRole: string;
  publications?: Publication[];
  institutionalUrl?: string;
  /** Personal or lab site, distinct from the institutional page. */
  personalUrl?: string;
  /** Path under /public, e.g. "team/bell.webp". Only rendered if Bell approved photos. */
  photo?: string;
}

const {
  name,
  affiliation,
  shortRole,
  publications = [],
  institutionalUrl,
  personalUrl,
  photo,
}: Props = Astro.props;
---

<article class="person">
  {photo && (
    /*
      Photo rendered only if a path is provided. [PENDING BELL APPROVAL on
      leadership photos] — if not approved, no photo path is set and the card
      reads cleanly without one. Monochrome treatment applied via CSS filter.
    */
    <img
      class="person__photo"
      src={`/${photo}`}
      alt={`Portrait of ${name}.`}
      width="120"
      height="120"
      loading="lazy"
      decoding="async"
    />
  )}

  <div class="person__body">
    <h3 class="person__name">{name}</h3>
    <p class="person__affil">{affiliation}</p>
    <p class="person__role">{shortRole}</p>

    <div class="person__bio">
      <slot />
    </div>

    {publications.length > 0 && (
      <div class="person__pubs">
        <h4 class="person__pubs-h">Selected publications</h4>
        <ul>
          {publications.map((pub) => (
            <li>
              {pub.citation}
              {pub.doi && (
                <>
                  {" "}
                  <a href={pub.doi} rel="noopener noreferrer" class="person__doi">
                    {pub.doi.replace(/^https?:\/\//, "")} <span aria-hidden="true">↗</span>
                  </a>
                </>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}

    {(institutionalUrl || personalUrl) && (
      <p class="person__link">
        {institutionalUrl && (
          <a href={institutionalUrl} rel="noopener noreferrer">
            Institutional page <span aria-hidden="true">↗</span>
          </a>
        )}
        {institutionalUrl && personalUrl && <span class="person__link-sep" aria-hidden="true"> · </span>}
        {personalUrl && (
          <a href={personalUrl} rel="noopener noreferrer">
            Personal site <span aria-hidden="true">↗</span>
          </a>
        )}
      </p>
    )}
  </div>
</article>

<style>
  .person {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--color-border);
  }
  .person:first-of-type { border-top: 0; padding-top: var(--space-3); }
  @media (min-width: 640px) {
    .person:has(.person__photo) {
      grid-template-columns: 120px 1fr;
      gap: var(--space-5);
    }
  }

  .person__photo {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: var(--radius);
    filter: grayscale(100%) contrast(1.05);
    background: var(--color-surface);
  }

  .person__name {
    font-family: var(--font-serif);
    font-size: var(--text-h3);
    font-weight: 600;
    margin: 0;
    color: var(--color-ink);
  }
  .person__affil {
    margin: var(--space-1) 0 0;
    color: var(--color-ink);
    font-size: var(--text-body);
  }
  .person__role {
    margin: var(--space-1) 0 0;
    color: var(--color-ink-muted);
    font-size: var(--text-small);
    font-style: italic;
  }
  .person__bio {
    margin-top: var(--space-3);
    color: var(--color-ink);
    max-width: 65ch;
  }
  .person__bio :global(p) { margin: 0 0 var(--space-3); }
  .person__bio :global(p:last-child) { margin-bottom: 0; }

  .person__pubs { margin-top: var(--space-4); }
  .person__pubs-h {
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-subtle);
    font-weight: 500;
    margin: 0 0 var(--space-2);
  }
  .person__pubs ul {
    margin: 0;
    padding-left: var(--space-4);
    list-style-type: square;
  }
  .person__pubs li {
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    margin-bottom: var(--space-2);
    max-width: 65ch;
  }
  .person__doi {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-border-strong);
    text-underline-offset: 0.15em;
    word-break: break-word;
  }
  .person__doi:hover { color: var(--color-accent); text-decoration-color: var(--color-accent); }

  .person__link { margin-top: var(--space-3); }
  .person__link-sep { color: var(--color-ink-subtle); }
  .person__link a {
    color: var(--color-ink);
    font-size: var(--text-small);
    text-decoration: underline;
    text-decoration-color: var(--color-border-strong);
    text-underline-offset: 0.2em;
  }
  .person__link a:hover { color: var(--color-accent); text-decoration-color: var(--color-accent); }
</style>
