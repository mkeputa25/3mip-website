---
/**
 * Footer — per docs/IA.md § Footer information architecture, restyled in
 * Phase 4e (DECISIONS-V2 V4/V6).
 *
 * Sections: wordmark + tagline + contact / quick links / project links /
 * legal — then the colophon: Fraunces italic, hairline above, carrying the
 * type credit, stack credit, licenses, and the git last-updated date.
 *
 * No upper-case anywhere; tracking carries the label register.
 */
import Wordmark from "./Wordmark.astro";
import { getLastUpdated, formatLongDate } from "../lib/last-updated";

const lastUpdated = getLastUpdated();

// [PENDING BELL APPROVAL — final GitHub URL]
const GITHUB_URL = "https://github.com/3mip-project/3mip-website";

const QUICK_LINKS = [
  { href: "/about/", label: "About" },
  { href: "/participate/", label: "Participate" },
  { href: "/outputs/", label: "Outputs" },
  { href: "/contact/", label: "Contact" },
];

const PROJECT_LINKS = [
  { href: GITHUB_URL, label: "GitHub", external: true },
  { href: "/news/feed.xml", label: "RSS feed" },
  { href: "#cite", label: "Cite this site" },
];

const LEGAL_LINKS = [
  { href: "/privacy/", label: "Privacy" },
  { href: "/accessibility/", label: "Accessibility" },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <Wordmark size="small" />
      <p class="site-footer__tagline">
        Mobility and Migration Modeling Intercomparison Project
      </p>
      <p class="site-footer__contact">
        <a href="mailto:mk2674@cornell.edu">mk2674@cornell.edu</a>
      </p>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__h">Quick links</h2>
      <ul class="site-footer__list">
        {QUICK_LINKS.map((l) => (
          <li><a href={l.href} class="underline-slide">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__h">Project</h2>
      <ul class="site-footer__list">
        {PROJECT_LINKS.map((l) => (
          <li>
            <a
              href={l.href}
              class="underline-slide"
              rel={l.external ? "noopener noreferrer" : undefined}
            >
              {l.label}{l.external ? " ↗" : ""}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__h">Legal</h2>
      <ul class="site-footer__list">
        {LEGAL_LINKS.map((l) => (
          <li><a href={l.href} class="underline-slide">{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  {/* Colophon (V6): Fraunces italic, hairline above. */}
  <div class="site-footer__colophon-wrap">
    <p class="site-footer__colophon">
      This website set in Fraunces and Geist. Built with Astro and deployed
      on Vercel. Content licensed under
      <a href="https://creativecommons.org/licenses/by/4.0/" rel="noopener noreferrer">CC BY 4.0</a>;
      code under
      <a href="https://opensource.org/licenses/MIT" rel="noopener noreferrer">MIT</a>.
      Last updated <time datetime={lastUpdated}>{formatLongDate(lastUpdated)}</time>.
      No analytics, no third-party trackers.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-background);
    border-top: 1px solid var(--color-border);
    color: var(--color-ink-muted);
    margin-top: var(--space-8);
  }

  .site-footer__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-6) var(--space-3);
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
      padding: var(--space-6) var(--space-4);
    }
  }
  @media (min-width: 1024px) {
    .site-footer__inner {
      grid-template-columns: 2fr 1fr 1fr 1.4fr;
      padding: var(--space-7) var(--space-5);
    }
  }

  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .site-footer__tagline {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    max-width: 32ch;
    margin: 0;
  }
  .site-footer__contact {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    margin: 0;
  }
  .site-footer__contact a {
    color: var(--color-ink);
  }

  /* Column headings: Geist 500 + tracking — no upper-case (V4). */
  .site-footer__h {
    font-family: var(--font-sans);
    font-variation-settings: normal;
    font-size: var(--text-caption);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-3);
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-small);
  }
  .site-footer__list a {
    color: var(--color-ink);
  }
  .site-footer__list a:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Colophon */
  .site-footer__colophon-wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--space-4) var(--space-3) var(--space-6);
  }
  @media (min-width: 640px) {
    .site-footer__colophon-wrap { padding-inline: var(--space-4); }
  }
  @media (min-width: 1024px) {
    .site-footer__colophon-wrap { padding-inline: var(--space-5); }
  }
  .site-footer__colophon {
    margin: 0;
    padding-top: var(--space-3);
    border-top: var(--hairline) solid var(--color-border-strong);
    font-family: var(--font-serif);
    font-variation-settings: var(--fraunces-text);
    font-style: italic;
    font-size: 0.75rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
    max-width: none;
  }
  .site-footer__colophon a {
    color: var(--color-ink-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-border-strong);
    text-underline-offset: 0.2em;
  }
  .site-footer__colophon a:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }
</style>
