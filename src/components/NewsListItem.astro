---
/**
 * NewsListItem — one entry in the reverse-chronological News list.
 *
 * Per docs/CONTENT-INVENTORY.md § News § Section 2: date (long format),
 * title (linked only if a full post exists), 2–3 sentence excerpt, tags.
 */
interface Props {
  title: string;
  /** ISO date for <time>. */
  date: string;
  /** Long display date, e.g. "October 2025". */
  dateLabel: string;
  excerpt: string;
  tags?: string[];
  /** Permalink to the full post, only set when fullPost is true. */
  href?: string;
}

const { title, date, dateLabel, excerpt, tags = [], href }: Props = Astro.props;
---

<article class="news-item">
  <time datetime={date} class="news-item__date">{dateLabel}</time>
  <h2 class="news-item__title">
    {href ? <a href={href}>{title}</a> : title}
  </h2>
  <p class="news-item__excerpt">{excerpt}</p>
  {tags.length > 0 && (
    <ul class="news-item__tags" aria-label="Tags">
      {tags.map((t) => <li>{t}</li>)}
    </ul>
  )}
</article>

<style>
  .news-item {
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-border);
    max-width: 65ch;
  }
  .news-item:first-of-type { border-top: 0; }
  .news-item__date {
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    font-weight: 500;
  }
  .news-item__title {
    font-family: var(--font-serif);
    font-size: var(--text-h3);
    font-weight: 600;
    margin: var(--space-2) 0 var(--space-2);
  }
  .news-item__title a {
    color: var(--color-ink);
    text-decoration: none;
  }
  .news-item__title a:hover { color: var(--color-accent); text-decoration: underline; text-underline-offset: 0.2em; }
  .news-item__excerpt {
    margin: 0;
    color: var(--color-ink-muted);
  }
  .news-item__tags {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .news-item__tags li {
    font-size: var(--text-caption);
    color: var(--color-ink-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2px var(--space-2);
  }
</style>
