---
/**
 * Wordmark — "3MIP" set in Fraunces at the wordmark axes
 * (opsz 72 / SOFT 100 / WONK 1, weight 500) with a hairline underrule at
 * half the wordmark width. DECISIONS-V2 V6.
 *
 * Used in the header, footer, and 404; the favicon carries a raster-style
 * "3M" variant of the same voice.
 */
interface Props {
  as?: "a" | "span";
  /** Smaller variant for the footer. */
  size?: "default" | "small";
  class?: string;
}

const {
  as = "a",
  size = "default",
  class: className = "",
}: Props = Astro.props;

const sizeClass = size === "small" ? "wordmark--small" : "";
---

{
  as === "a" ? (
    <a href="/" class={`wordmark ${sizeClass} ${className}`} aria-label="3MIP home">
      <span class="wordmark__text" aria-hidden="true">3MIP</span>
      <span class="vh">3MIP — Mobility and Migration Modeling Intercomparison Project</span>
    </a>
  ) : (
    <span class={`wordmark ${sizeClass} ${className}`} aria-label="3MIP">
      <span class="wordmark__text" aria-hidden="true">3MIP</span>
    </span>
  )
}

<style>
  .wordmark {
    display: inline-block;
    text-decoration: none;
    color: var(--color-ink);
  }
  a.wordmark:hover .wordmark__text {
    color: var(--color-accent);
  }
  a.wordmark:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .wordmark__text {
    display: block;
    font-family: var(--font-serif);
    font-variation-settings: var(--fraunces-wordmark);
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: -0.01em;
    transition: color 150ms var(--ease-out);
  }

  /* Hairline underrule at half the wordmark width (V6). */
  .wordmark__text::after {
    content: "";
    display: block;
    width: 50%;
    margin-top: 3px;
    border-top: var(--hairline) solid var(--color-border-strong);
  }

  .wordmark--small .wordmark__text {
    font-size: 1.125rem;
  }
</style>
