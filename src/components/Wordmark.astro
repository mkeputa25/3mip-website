---
/**
 * Wordmark — the 3MIP logo mark (DECISIONS-V2 V6, logo adopted June 2026).
 *
 * Recreates the project's logo concept — a chevron "3" zigzag + "MIP" in a
 * high-contrast serif + a play triangle, reading as "3MIP" — as a crisp,
 * scalable inline SVG. Rendered in the site palette (terracotta + ink),
 * NOT the sage green of the original raster: a green mark would fight the
 * terracotta system and the brief's avoid-green-for-climate-work rule. The
 * structure is faithful; the color is harmonized. [B11 resolved to this mark.]
 *
 * "MIP" is set in Fraunces (the loaded display face) via <text>, with a
 * Didone fallback stack so it reads high-contrast even before the webfont
 * settles. The whole SVG is decorative (aria-hidden); the accessible name
 * comes from the link/span label.
 *
 * Renders as a link to "/" by default; Home passes as="span".
 */
interface Props {
  as?: "a" | "span";
  /** Smaller variant for the footer. */
  size?: "default" | "small";
  class?: string;
}

const {
  as = "a",
  size = "default",
  class: className = "",
}: Props = Astro.props;

const sizeClass = size === "small" ? "wordmark--small" : "";
const Tag = as;
---

<Tag
  class={`wordmark ${sizeClass} ${className}`}
  href={as === "a" ? "/" : undefined}
  aria-label={as === "a" ? "3MIP home" : "3MIP"}
>
  <svg class="wordmark__svg" viewBox="0 0 84 30" role="img" aria-hidden="true" focusable="false">
    {/* Chevron "3" — a continuous terracotta zigzag. */}
    <path
      d="M4 3 L13 9 L4 15 L13 21 L4 27"
      fill="none"
      stroke="var(--color-accent)"
      stroke-width="2.4"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    {/* MIP — Fraunces display, ink, high contrast. */}
    <text
      x="20"
      y="23"
      class="wordmark__letters"
      fill="var(--color-ink)"
    >MIP</text>
    {/* Play triangle — terracotta, tucked against the P, echoing the original mark. */}
    <path d="M73 10.5 L81 15 L73 19.5 Z" fill="var(--color-accent)" />
  </svg>
  <span class="vh">3MIP — Mobility and Migration Modeling Intercomparison Project</span>
</Tag>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 0;
  }
  a.wordmark:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .wordmark__svg {
    height: 30px;
    width: auto;
    display: block;
    transition: opacity 150ms var(--ease-out);
  }
  a.wordmark:hover .wordmark__svg { opacity: 0.82; }

  .wordmark--small .wordmark__svg { height: 24px; }

  .wordmark__letters {
    font-family: var(--font-serif), "Didot", "Bodoni 72", serif;
    font-variation-settings: "opsz" 40, "SOFT" 0, "WONK" 0;
    font-weight: 600;
    font-size: 26px;
    letter-spacing: -0.5px;
  }
</style>
