---
/**
 * TimelineList — vertical list of dated milestones.
 *
 * Used on the Case 1 page § Expected outputs and timeline. Layout: two-column
 * (date | event) on tablet+, stacked on mobile.
 *
 * Each item can carry a "kind" that styles the bullet:
 *   active (default), done, planned, aspirational.
 *
 * Accessible: ordered list semantics, dates as <time datetime="…">.
 */
type Kind = "active" | "done" | "planned" | "aspirational";

interface Item {
  /** ISO 8601 date or short date string. Display label can differ via `dateLabel`. */
  date: string;
  /** Optional override for the displayed date text (e.g., "Late 2026 onward"). */
  dateLabel?: string;
  text: string;
  kind?: Kind;
}

interface Props {
  items: Item[];
  class?: string;
}

const { items, class: className = "" }: Props = Astro.props;
---

<ol class={`timeline ${className}`}>
  {items.map((it) => (
    <li class={`timeline__item timeline__item--${it.kind ?? "active"}`}>
      <div class="timeline__bullet" aria-hidden="true"></div>
      <div class="timeline__date">
        <time datetime={it.date}>{it.dateLabel ?? it.date}</time>
      </div>
      <div class="timeline__text" set:html={it.text} />
    </li>
  ))}
</ol>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    border-left: 2px solid var(--color-border);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-3) var(--space-3) var(--space-4);
    position: relative;
  }
  @media (min-width: 640px) {
    .timeline__item {
      grid-template-columns: 12rem 1fr;
      gap: var(--space-4);
    }
  }

  .timeline__bullet {
    position: absolute;
    left: -7px;
    top: calc(var(--space-3) + 6px);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-background);
    border: 2px solid var(--color-border-strong);
  }

  .timeline__item--done .timeline__bullet {
    background: var(--color-ink);
    border-color: var(--color-ink);
  }
  .timeline__item--active .timeline__bullet {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .timeline__item--aspirational .timeline__bullet {
    background: var(--color-background);
    border-color: var(--color-border-strong);
    border-style: dashed;
  }

  .timeline__date {
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    font-weight: 500;
  }

  .timeline__text {
    font-size: var(--text-body);
    color: var(--color-ink);
    line-height: var(--text-body--line-height);
    max-width: 65ch;
  }
  .timeline__text :global(em) {
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
