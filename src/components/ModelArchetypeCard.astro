---
/**
 * ModelArchetypeCard — one of the six model families shown in the signature
 * figure. Each card pairs a plain-language gloss with a tiny glyph drawn in
 * the SAME visual grammar as that panel in the signature viz (dots for ABM,
 * arcs for gravity, rings for radiation, blocks for IAM, contours for ML,
 * cells for cellular). The glyph teaches the reader what they're looking at.
 *
 * `data-arch` carries the archetype key so 5G can cross-highlight the matching
 * panel in the figure above. The card is informational (not a link); it does
 * not navigate.
 */
interface Props {
  name: string;
  gloss: string;
  kind: "abm" | "gravity" | "radiation" | "iam" | "ml" | "cellular";
}
const { name, gloss, kind } = Astro.props;
---

<article class="archcard" data-arch={kind}>
  <span class="archcard__glyph" aria-hidden="true">
    {kind === "abm" && (
      <svg viewBox="0 0 44 44"><g fill="currentColor">
        <circle cx="10" cy="12" r="2.4" /><circle cx="20" cy="9" r="2" />
        <circle cx="31" cy="14" r="2.6" /><circle cx="14" cy="24" r="2" />
        <circle cx="25" cy="22" r="3" /><circle cx="34" cy="28" r="2.2" />
        <circle cx="11" cy="33" r="2.6" /><circle cx="23" cy="34" r="2" />
      </g></svg>
    )}
    {kind === "gravity" && (
      <svg viewBox="0 0 44 44"><g fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M8 34 Q 22 6 36 16" /><path d="M8 34 Q 18 18 33 28" stroke-width="2.4" />
        <path d="M8 34 Q 26 30 37 34" stroke-width="1" />
      </g><g fill="currentColor"><circle cx="8" cy="34" r="2.6" /><circle cx="36" cy="16" r="2" /><circle cx="33" cy="28" r="2" /><circle cx="37" cy="34" r="1.6" /></g></svg>
    )}
    {kind === "radiation" && (
      <svg viewBox="0 0 44 44"><g fill="none" stroke="currentColor" stroke-width="1.3">
        <circle cx="22" cy="22" r="5" /><circle cx="22" cy="22" r="10" opacity="0.8" />
        <circle cx="22" cy="22" r="15" opacity="0.55" /><circle cx="22" cy="22" r="20" opacity="0.3" />
      </g><circle cx="22" cy="22" r="2" fill="currentColor" /></svg>
    )}
    {kind === "iam" && (
      <svg viewBox="0 0 44 44"><g fill="currentColor">
        <rect x="7" y="8" width="13" height="13" rx="1.5" opacity="0.55" />
        <rect x="24" y="8" width="13" height="13" rx="1.5" opacity="0.85" />
        <rect x="7" y="24" width="13" height="13" rx="1.5" opacity="0.85" />
        <rect x="24" y="24" width="13" height="13" rx="1.5" opacity="0.4" />
      </g></svg>
    )}
    {kind === "ml" && (
      <svg viewBox="0 0 44 44"><g fill="none" stroke="currentColor" stroke-width="1.3">
        <path d="M6 30 Q 22 22 38 30" /><path d="M6 24 Q 22 14 38 24" opacity="0.8" />
        <path d="M6 18 Q 22 8 38 18" opacity="0.55" /><path d="M6 12 Q 22 4 38 12" opacity="0.3" />
      </g></svg>
    )}
    {kind === "cellular" && (
      <svg viewBox="0 0 44 44"><g fill="currentColor">
        <rect x="8" y="8" width="8" height="8" /><rect x="18" y="8" width="8" height="8" opacity="0.35" />
        <rect x="28" y="8" width="8" height="8" opacity="0.7" /><rect x="8" y="18" width="8" height="8" opacity="0.7" />
        <rect x="18" y="18" width="8" height="8" /><rect x="28" y="18" width="8" height="8" opacity="0.35" />
        <rect x="8" y="28" width="8" height="8" opacity="0.35" /><rect x="18" y="28" width="8" height="8" opacity="0.7" />
        <rect x="28" y="28" width="8" height="8" />
      </g></svg>
    )}
  </span>
  <h3 class="archcard__name">{name}</h3>
  <p class="archcard__gloss">{gloss}</p>
</article>

<style>
  .archcard {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
    transition: border-color 150ms var(--ease-out);
  }
  .archcard__glyph {
    display: block;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--accent-teal);
    margin-bottom: var(--space-3);
  }
  .archcard__glyph svg { width: 100%; height: 100%; }
  .archcard__name {
    font-family: var(--font-serif);
    font-size: var(--text-h4);
    margin: 0 0 var(--space-1);
  }
  .archcard__gloss {
    margin: 0;
    color: var(--color-ink-muted);
    font-size: var(--text-small);
    line-height: 1.5;
  }
  /* 5G hook: when the card is the active cross-highlight target. */
  .archcard.is-active,
  .archcard:hover { border-color: var(--accent-teal); }
</style>
