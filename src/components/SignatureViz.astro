  /* ═══════════════════════════════════════════════════════════════════
     KINETIC GRAMMAR (Phase 2d) — class-gated: animations exist only under
     .is-playing, so the base document is exactly the static plate. All
     durations divide the shared 14s loop; everything is deterministic.
     The global reduced-motion rule additionally neutralizes all of this.
     ═══════════════════════════════════════════════════════════════════ */

  /* 01 — agents drift toward the corridor; faders relocate. */
  .sigviz.is-playing .ka-dot {
    animation: abm-drift var(--loop) ease-in-out infinite;
  }
  .sigviz.is-playing .ka-fade {
    animation: abm-relocate var(--loop) ease-in-out infinite;
  }
  @keyframes abm-drift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(var(--dx), var(--dy)); }
  }
  @keyframes abm-relocate {
    0%, 14% { opacity: 1; transform: translate(0, 0); }
    20%, 24% { opacity: 0; transform: translate(0, 0); }
    25% { opacity: 0; transform: translate(var(--dx2), var(--dy2)); }
    32%, 72% { opacity: 1; transform: translate(var(--dx2), var(--dy2)); }
    80%, 88% { opacity: 0; transform: translate(var(--dx2), var(--dy2)); }
    89% { opacity: 0; transform: translate(0, 0); }
    96%, 100% { opacity: 1; transform: translate(0, 0); }
  }

  /* 02 — arcs draw in over the first ~2s, then pulse with flow weight. */
  .sigviz.is-playing .ka-arc {
    stroke-dasharray: 100;
    animation: arc-flow var(--loop) linear infinite;
  }
  @keyframes arc-flow {
    0% { stroke-dashoffset: 100; opacity: 0; }
    4% { opacity: var(--op); }
    14% { stroke-dashoffset: 0; opacity: var(--op); }
    25% { opacity: calc(var(--op) * 0.55); }
    36% { opacity: var(--op); }
    47% { opacity: calc(var(--op) * 0.55); }
    58% { opacity: var(--op); }
    69% { opacity: calc(var(--op) * 0.55); }
    80% { opacity: var(--op); }
    90% { opacity: calc(var(--op) * 0.55); }
    100% { opacity: var(--op); }
  }

  /* 03 — rings ripple outward in sequence; 2.8s × 5 = the 14s loop. */
  .sigviz.is-playing .ka-ring {
    animation: ring-ripple 2.8s ease-out infinite;
    animation-delay: var(--rd);
  }
  @keyframes ring-ripple {
    0% { opacity: 1; }
    25% { opacity: 0.35; }
    60%, 100% { opacity: 1; }
  }
  .sigviz.is-playing .ka-focus {
    transform-box: fill-box;
    transform-origin: center;
    animation: focus-pulse 2.8s ease-out infinite;
  }
  @keyframes focus-pulse {
    0% { transform: scale(1); }
    12% { transform: scale(1.3); }
    35%, 100% { transform: scale(1); }
  }

  /* 04 — fills jump through five discrete states; steps(1, end) makes
     every transition a cut, not a tween. The jump IS the meaning. */
  .sigviz.is-playing .ka-region {
    animation: region-steps var(--loop) steps(1, end) infinite;
  }
  @keyframes region-steps {
    0% { fill: var(--f1); }
    20% { fill: var(--f2); }
    40% { fill: var(--f3); }
    60% { fill: var(--f4); }
    80% { fill: var(--f5); }
    100% { fill: var(--f1); }
  }

  /* 05 — three surface states crossfade on staggered thirds of the loop. */
  .sigviz.is-playing .ka-ml {
    animation: ml-fade var(--loop) ease-in-out infinite;
    animation-delay: var(--md);
  }
  @keyframes ml-fade {
    0% { opacity: 1; }
    28% { opacity: 1; }
    36% { opacity: 0; }
    92% { opacity: 0; }
    100% { opacity: 1; }
  }

  /* 06 — generational ticks: dying cells vanish for ~4.5s windows, born
     cells appear in theirs. steps(1, end) keeps changes discrete. */
  .sigviz.is-playing .ka-cell-die {
    animation: cell-die var(--loop) steps(1, end) infinite;
    animation-delay: var(--cd);
  }
  .sigviz.is-playing .ka-cell-born {
    animation: cell-born var(--loop) steps(1, end) infinite;
    animation-delay: var(--cd);
  }
  @keyframes cell-die {
    0% { opacity: 1; }
    2% { opacity: 0; }
    32% { opacity: 0; }
    34% { opacity: 1; }
    100% { opacity: 1; }
  }
  @keyframes cell-born {
    0% { opacity: 0; }
    2% { opacity: 1; }
    32% { opacity: 1; }
    34% { opacity: 0; }
    100% { opacity: 0; }
  }

  /* Year readout windows: each label visible for its sixth of the loop. */
  .sigviz.is-playing .ka-year {
    animation: year-window var(--loop) infinite;
    animation-delay: var(--yd);
  }
  @keyframes year-window {
    0% { opacity: 1; }
    16.6% { opacity: 1; }
    16.7% { opacity: 0; }
    100% { opacity: 0; }
  }
</style>

<!--
  Kinetic controller (~0.8KB): in-view play/pause + user toggle.
  - Reduced motion: early return — the button never appears, the figure
    stays the static plate, the timeline row is hidden by CSS.
  - Without JS: same static plate, no button, no timeline row.
  - "Pause" stops the loop (returns to the canonical static figure);
    WCAG 2.2.2 permits pause or stop. Re-entering view restarts the
    deterministic loop from 2025.
-->
<script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll('[data-kinetic]').forEach(function (fig) {
      var btn = fig.querySelector('[data-viz-toggle]');
      var userPaused = false;
      var inView = false;
      function sync() {
        var play = inView && !userPaused;
        fig.classList.toggle('is-playing', play);
        if (btn) {
          btn.setAttribute('aria-pressed', String(userPaused));
          btn.setAttribute('aria-label', userPaused ? 'Play the figure animation' : 'Pause the figure animation');
          btn.textContent = userPaused ? 'Play' : 'Pause';
        }
      }
      if (btn) {
        btn.hidden = false;
        btn.addEventListener('click', function () {
          userPaused = !userPaused;
          sync();
        });
      }
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { inView = e.isIntersecting; });
          sync();
        }, { threshold: 0.2 }).observe(fig);
      }
      sync();
    });
  })();
</script>
