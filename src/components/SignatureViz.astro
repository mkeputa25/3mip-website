---
/**
 * SignatureViz — the 3MIP signature figure: atlas plate (Phase 2c) made
 * kinetic (Phase 2d, DECISIONS-V2 V9 Tier 3).
 *
 * THE CORE IDEA: each panel's motion grammar mirrors its model's
 * computational logic. The animation is the methodological argument,
 * kinetic. One shared ~14s loop represents simulation time 2025 → 2050,
 * labeled by a Geist Mono year readout beneath the plate furniture.
 *
 *   01 Agent-based   dots drift toward the Dhaka corridor; three dots
 *                    fade out at origin and re-fade-in displaced
 *                    (individual-level simulation)
 *   02 Gravity       arcs draw in (stroke-dashoffset, first ~2s), then
 *                    pulse opacity with flow weight (steady-state flows)
 *   03 Radiation     rings ripple outward sequentially, 2.8s cascade
 *                    (distance-decay propagation; 2.8 × 5 = the 14s loop)
 *   04 IAM           region fills JUMP through 5 discrete states — no
 *                    tweening; the jump cut is the meaning (time steps)
 *   05 ML            contour surface crossfades between 3 precomputed
 *                    states (continuous prediction surface)
 *   06 Cellular      cells die/appear in discrete generations, one tick
 *                    per 1.4s (the CA update rule made visible)
 *
 * MOTION ARCHITECTURE — class-gated, not play-state-paused:
 * every animation exists only under `.sigviz.is-playing`. The base
 * (non-playing) document IS today's static plate — exactly what no-JS
 * visitors, reduced-motion users, and the Phase 6 static SVG export get.
 * "Pause" therefore returns to the canonical figure rather than freezing
 * mid-frame (WCAG 2.2.2 permits pause or stop; stop is cleaner here).
 *
 * Controls: plays when scrolled into view, pauses out of view (own
 * IntersectionObserver); visible ghost pause/play button (hidden until
 * the controller enables it; never enabled under reduced motion).
 * Nothing changes faster than ~1 event per 0.7s in any region
 * (WCAG 2.3.1: well under 3/sec; no flashing).
 *
 * Everything is deterministic: hand-authored geometry, pure-function
 * cell states, fixed delays. Same animation every load. No rAF, no
 * canvas, no library. Controller ≈0.8KB; system total ≈1.3KB of the
 * ≤3KB budget.
 *
 * [PENDING BELL APPROVAL]: archetype choice + per-panel pattern story.
 */

import {
  BANGLADESH_PATH,
  BANGLADESH_DISTRICT_LINES,
} from "../lib/bangladesh-outline";

interface Props {
  class?: string;
  /** Unique id base for ARIA/clip ids when the figure appears on multiple pages. */
  idBase?: string;
}

const { class: className = "", idBase = "sigviz" } = Astro.props;

const RAMP = ["#F5EFE4", "#E8B98A", "#D08A6E", "#B85A35", "#8E3A22", "#6B1F1F"] as const;
const LOOP_S = 14;

/* ── 01 Agent-based: dot field + drift vectors toward the Dhaka corridor. */
type Tone = "accent" | "deep" | "dim";
const ABM_DOTS_BASE: ReadonlyArray<{ x: number; y: number; r: number; t: Tone }> = [
  { x: 55, y: 150, r: 3.2, t: "deep" },
  { x: 70, y: 142, r: 2.2, t: "accent" },
  { x: 84, y: 152, r: 4.2, t: "deep" },
  { x: 96, y: 140, r: 2.8, t: "accent" },
  { x: 108, y: 148, r: 3.6, t: "deep" },
  { x: 122, y: 152, r: 2.4, t: "dim" },
  { x: 135, y: 144, r: 3.0, t: "accent" },
  { x: 150, y: 152, r: 2.0, t: "dim" },
  { x: 166, y: 148, r: 2.6, t: "accent" },
  { x: 185, y: 152, r: 2.2, t: "dim" },
  { x: 90, y: 122, r: 2.6, t: "accent" },
  { x: 104, y: 112, r: 3.4, t: "deep" },
  { x: 98, y: 96, r: 2.4, t: "accent" },
  { x: 112, y: 84, r: 2.8, t: "accent" },
  { x: 107, y: 68, r: 3.8, t: "deep" },
  { x: 120, y: 60, r: 2.4, t: "dim" },
  { x: 131, y: 96, r: 2.2, t: "dim" },
  { x: 144, y: 118, r: 2.6, t: "accent" },
  { x: 74, y: 112, r: 2.0, t: "dim" },
  { x: 58, y: 128, r: 2.4, t: "accent" },
];
const DHAKA = { x: 112, y: 62 } as const;
/* Indices of the 2–3 dots that relocate (fade out at origin, re-fade-in
   displaced further along the corridor). */
const ABM_FADERS = new Set([3, 9, 17]);
const ABM_DOTS = ABM_DOTS_BASE.map((d, i) => {
  const vx = DHAKA.x - d.x;
  const vy = DHAKA.y - d.y;
  const len = Math.hypot(vx, vy) || 1;
  const mag = Math.min(9, len * 0.1);
  const dx = +((vx / len) * mag).toFixed(1);
  const dy = +((vy / len) * mag).toFixed(1);
  return { ...d, i, dx, dy, dx2: +(dx * 2.6).toFixed(1), dy2: +(dy * 2.6).toFixed(1), fades: ABM_FADERS.has(i) };
});
const TONE_VAR: Record<Tone, string> = {
  accent: "var(--color-accent)",
  deep: "var(--color-accent-deep)",
  dim: "var(--color-accent-dim)",
};

/* ── 02 Gravity: origins, destinations, arcs. pathLength=100 normalizes
   the dash draw-in regardless of true arc length. */
const GRAVITY_ORIGINS = [
  { x: 58, y: 148 }, { x: 92, y: 154 }, { x: 128, y: 150 },
  { x: 162, y: 150 }, { x: 196, y: 148 },
] as const;
const GRAVITY_DESTS = [
  { x: 112, y: 62, r: 5 },
  { x: 78, y: 124, r: 4 },
  { x: 214, y: 128, r: 4 },
] as const;
const GRAVITY_ARCS: ReadonlyArray<{ o: number; d: number; cx: number; cy: number; w: number; op: number }> = [
  { o: 0, d: 0, cx: 70, cy: 95, w: 2.6, op: 0.85 },
  { o: 1, d: 0, cx: 95, cy: 100, w: 3.0, op: 0.9 },
  { o: 1, d: 1, cx: 82, cy: 142, w: 1.4, op: 0.6 },
  { o: 2, d: 0, cx: 122, cy: 100, w: 2.2, op: 0.75 },
  { o: 3, d: 0, cx: 140, cy: 100, w: 1.2, op: 0.55 },
  { o: 3, d: 2, cx: 190, cy: 142, w: 1.6, op: 0.65 },
  { o: 4, d: 2, cx: 208, cy: 140, w: 2.0, op: 0.7 },
  { o: 0, d: 1, cx: 66, cy: 140, w: 1.0, op: 0.5 },
];

/* ── 03 Radiation: focal point + rings; cascade delay = index × 0.35s,
   ripple period 2.8s (×5 = the 14s loop). */
const RADIATION_FOCUS = { x: 112, y: 62 } as const;
const RADIATION_RINGS: ReadonlyArray<{ r: number; w: number; color: string }> = [
  { r: 12, w: 1.4, color: RAMP[5] },
  { r: 26, w: 1.1, color: RAMP[4] },
  { r: 44, w: 0.85, color: RAMP[3] },
  { r: 66, w: 0.65, color: RAMP[2] },
  { r: 92, w: 0.5, color: RAMP[1] },
];

/* ── 04 IAM: regions + 5 precomputed fill states each. State 1 is the
   static figure; the loop jumps 1→2→3→4→5→1 with no tweening. */
const IAM_REGIONS: ReadonlyArray<{ d: string; states: readonly [number, number, number, number, number] }> = [
  { d: "M 20 25 L 105 25 L 100 80 L 60 95 L 18 80 Z", states: [2, 2, 3, 3, 2] },
  { d: "M 105 25 L 245 25 L 240 95 L 165 100 L 100 80 Z", states: [1, 2, 2, 3, 2] },
  { d: "M 18 80 L 60 95 L 100 80 L 110 130 L 60 140 L 20 130 Z", states: [3, 3, 4, 4, 3] },
  { d: "M 20 130 L 110 130 L 165 135 L 160 185 L 15 185 Z", states: [5, 4, 4, 5, 5] },
  { d: "M 165 100 L 240 95 L 248 185 L 160 185 L 165 135 Z", states: [4, 3, 4, 5, 4] },
];

/* ── 05 ML: one band set, three precomputed surface states (the predicted
   surface migrates toward the corridor over simulation time). State A is
   the static figure; B and C are group-transformed copies that crossfade. */
const ML_BANDS: ReadonlyArray<{ d: string; fill: string }> = [
  {
    d: "M 30 95 C 55 70, 95 60, 130 75 C 170 90, 200 115, 195 140 C 188 165, 130 172, 90 165 C 50 158, 18 130, 30 95 Z",
    fill: RAMP[1],
  },
  {
    d: "M 50 105 C 70 85, 105 80, 132 95 C 158 108, 172 128, 162 145 C 150 160, 105 162, 78 152 C 55 143, 40 122, 50 105 Z",
    fill: RAMP[2],
  },
  {
    d: "M 68 115 C 84 100, 112 98, 130 110 C 146 121, 148 136, 136 146 C 122 155, 92 152, 78 142 C 66 133, 60 124, 68 115 Z",
    fill: RAMP[3],
  },
  {
    d: "M 86 122 C 96 114, 112 114, 122 122 C 130 129, 128 138, 118 142 C 106 146, 92 142, 86 134 C 82 129, 82 126, 86 122 Z",
    fill: RAMP[4],
  },
];
const ML_STATES = [
  { transform: undefined, delay: 0, base: 1 },
  { transform: "translate(7 -5)", delay: +(LOOP_S / 3).toFixed(3), base: 0 },
  { transform: "translate(13 -9)", delay: +((LOOP_S / 3) * 2).toFixed(3), base: 0 },
] as const;

/* ── 06 Cellular: static grid + generation ticks. ~8 cells die and ~6 are
   born across 10 ticks of 1.4s — a handful of state changes per
   generation, all deterministic from the cell index. */
const CELL_COLS = 10;
const CELL_ROWS = 8;
const CELL_W = 240 / CELL_COLS;
const CELL_H = 180 / CELL_ROWS;
function cellBin(c: number, r: number): number {
  const band = Math.sin((c + r * 1.4) * 0.7) * 2.8 + 1.6;
  const coastBoost = r > 4 ? (r - 4) * 0.7 : 0;
  return Math.max(0, Math.min(5, Math.round(band + coastBoost - 0.5)));
}
const GRID = Array.from({ length: CELL_COLS * CELL_ROWS }, (_, i) => {
  const c = i % CELL_COLS;
  const r = Math.floor(i / CELL_COLS);
  return { i, x: c * CELL_W, y: r * CELL_H, bin: cellBin(c, r) };
});
const CELLS = GRID.filter((cell) => cell.bin > 0);
const TICK_S = 1.4;
const DYING = CELLS.filter((cell) => cell.i % 6 === 2)
  .slice(0, 8)
  .map((cell) => ({ ...cell, tick: (cell.i * 7) % 10 }));
const DYING_IDS = new Set(DYING.map((d) => d.i));
const BORN = GRID.filter((cell) => cell.bin === 0)
  .filter((cell) => cell.i % 5 === 1)
  .slice(0, 6)
  .map((cell) => ({ ...cell, tick: (cell.i * 3 + 5) % 10 }));

/* ── Year readout: six labels across the 14s loop (2.333s each). */
const YEARS = ["2025", "2030", "2035", "2040", "2045", "2050"] as const;
const YEAR_WIN_S = +(LOOP_S / YEARS.length).toFixed(4);

/* ── Panel metadata: desc covers the static figure; motion is described in
   the visible long-form alternatives on the consuming pages. */
const PANELS = [
  {
    id: "abm", num: "01", title: "Agent-based",
    desc: "About twenty dots of varying size, denser along the southwest coast and the corridor toward Dhaka; each dot is one simulated household cluster. In motion, dots drift toward the corridor and a few relocate.",
  },
  {
    id: "gravity", num: "02", title: "Gravity",
    desc: "Flow arcs of varying thickness from five coastal origin points to three destination cities; thicker arcs are larger modeled flows. In motion, arcs draw in and pulse with flow weight.",
  },
  {
    id: "radiation", num: "03", title: "Radiation",
    desc: "Nested rings spreading from one focal point, spacing widening and color fading outward — distance-decaying catchments. In motion, rings ripple outward in sequence.",
  },
  {
    id: "iam", num: "04", title: "Integrated assessment",
    desc: "Five regional polygons, each filled with a single flat intensity value; no detail inside regions, because the model aggregates. In motion, fills jump between discrete time-step states.",
  },
  {
    id: "ml", num: "05", title: "Machine learning",
    desc: "Smooth nested contour bands deepening toward a coastal core — a continuous predicted surface with no hard edges. In motion, the surface crossfades between predicted states.",
  },
  {
    id: "cellular", num: "06", title: "Cellular automaton",
    desc: "A coarse grid of discrete cells in stepped intensities, clipped to the country outline. In motion, cells change state in discrete generations.",
  },
] as const;

const BOTTOM_ROW_IDS = new Set(["iam", "ml", "cellular"]);
---

<figure class={`sigviz ${className}`} data-kinetic>
  <!-- Figure header: eyebrow + title + question; Illustrative tag and the
       motion control right. The button stays hidden until the controller
       enables it (never under reduced motion; never without JS). -->
  <div class="sigviz__head">
    <div>
      <p class="eyebrow sigviz__fig">Fig. 01</p>
      <p class="sigviz__title">Six architectures, one question</p>
      <p class="sigviz__question">
        Net internal migration, coastal Bangladesh, 2025–2050, SSP2-4.5
      </p>
    </div>
    <div class="sigviz__head-tools">
      <span class="sigviz__tag" aria-hidden="true">Illustrative</span>
      <button
        type="button"
        class="sigviz__toggle"
        data-viz-toggle
        hidden
        aria-pressed="false"
        aria-label="Pause the figure animation"
      >Pause</button>
    </div>
  </div>

  <div class="sigviz__grid" role="group" aria-label="Six model architectures applied to the same question.">
    {PANELS.map((panel) => (
      <div class="sigviz__panel">
        <p class="sigviz__panel-title">
          <span class="sigviz__panel-num">{panel.num}</span>
          {panel.title}
        </p>
        <svg
          viewBox="0 0 240 180"
          role="img"
          aria-labelledby={`${idBase}-t-${panel.id} ${idBase}-d-${panel.id}`}
          class="sigviz__svg"
        >
          <title id={`${idBase}-t-${panel.id}`}>{panel.title} architecture, same question.</title>
          <desc id={`${idBase}-d-${panel.id}`}>{panel.desc}</desc>

          <defs>
            <clipPath id={`${idBase}-clip-${panel.id}`}>
              <path d={BANGLADESH_PATH} />
            </clipPath>
          </defs>

          {/* Land fill — design-locked literal (DECISIONS-V2 V8). */}
          <path d={BANGLADESH_PATH} fill="#EEE7D7" />

          {/* ── Architecture grammar, clipped to the landmass ── */}
          <g clip-path={`url(#${idBase}-clip-${panel.id})`}>
            {panel.id === "abm" &&
              ABM_DOTS.map((d) => (
                <circle
                  cx={d.x}
                  cy={d.y}
                  r={d.r}
                  fill={TONE_VAR[d.t]}
                  class={d.fades ? "ka-fade" : "ka-dot"}
                  style={`--dx:${d.dx}px; --dy:${d.dy}px; --dx2:${d.dx2}px; --dy2:${d.dy2}px;`}
                />
              ))}

            {panel.id === "radiation" && (
              <>
                {RADIATION_RINGS.map((ring, i) => (
                  <circle
                    cx={RADIATION_FOCUS.x}
                    cy={RADIATION_FOCUS.y}
                    r={ring.r}
                    fill="none"
                    stroke={ring.color}
                    stroke-width={ring.w}
                    class="ka-ring"
                    style={`--rd:${(i * 0.35).toFixed(2)}s;`}
                  />
                ))}
                <circle
                  cx={RADIATION_FOCUS.x}
                  cy={RADIATION_FOCUS.y}
                  r="3"
                  fill="var(--color-accent-deep)"
                  class="ka-focus"
                />
              </>
            )}

            {panel.id === "iam" &&
              IAM_REGIONS.map((region) => (
                <path
                  d={region.d}
                  fill={RAMP[region.states[0]]}
                  stroke="rgb(26 22 18 / 0.3)"
                  stroke-width="0.4"
                  class="ka-region"
                  style={`--f1:${RAMP[region.states[0]]}; --f2:${RAMP[region.states[1]]}; --f3:${RAMP[region.states[2]]}; --f4:${RAMP[region.states[3]]}; --f5:${RAMP[region.states[4]]};`}
                />
              ))}

            {panel.id === "ml" &&
              ML_STATES.map((state) => (
                <g
                  class="ka-ml"
                  transform={state.transform}
                  style={`--md:${state.delay}s; opacity:${state.base};`}
                >
                  {ML_BANDS.map((band) => <path d={band.d} fill={band.fill} />)}
                </g>
              ))}

            {panel.id === "cellular" && (
              <>
                {CELLS.map((cell) =>
                  DYING_IDS.has(cell.i) ? null : (
                    <rect x={cell.x} y={cell.y} width={CELL_W} height={CELL_H} fill={RAMP[cell.bin]} />
                  ),
                )}
                {DYING.map((cell) => (
                  <rect
                    x={cell.x}
                    y={cell.y}
                    width={CELL_W}
                    height={CELL_H}
                    fill={RAMP[cell.bin]}
                    class="ka-cell-die"
                    style={`--cd:${(cell.tick * TICK_S).toFixed(1)}s;`}
                  />
                ))}
                {BORN.map((cell) => (
                  <rect
                    x={cell.x}
                    y={cell.y}
                    width={CELL_W}
                    height={CELL_H}
                    fill={RAMP[2]}
                    class="ka-cell-born"
                    style={`--cd:${(cell.tick * TICK_S).toFixed(1)}s; opacity:0;`}
                  />
                ))}
              </>
            )}

            {/* District hairlines — over fills, under outline. */}
            {BANGLADESH_DISTRICT_LINES.map((line) => (
              <path d={line} fill="none" stroke="rgb(26 22 18 / 0.25)" stroke-width="0.3" />
            ))}
          </g>

          {/* Gravity flows sit above the clip: diagrammatic, not choropleth. */}
          {panel.id === "gravity" && (
            <>
              {GRAVITY_ARCS.map((arc) => {
                const o = GRAVITY_ORIGINS[arc.o];
                const d = GRAVITY_DESTS[arc.d];
                return (
                  <path
                    d={`M ${o.x} ${o.y} Q ${arc.cx} ${arc.cy} ${d.x} ${d.y}`}
                    fill="none"
                    stroke="var(--color-accent)"
                    stroke-width={arc.w}
                    stroke-linecap="round"
                    opacity={arc.op}
                    pathLength={100}
                    class="ka-arc"
                    style={`--op:${arc.op};`}
                  />
                );
              })}
              {GRAVITY_ORIGINS.map((o) => (
                <circle cx={o.x} cy={o.y} r="2" fill="var(--color-accent-deep)" />
              ))}
              {GRAVITY_DESTS.map((d) => (
                <circle
                  cx={d.x}
                  cy={d.y}
                  r={d.r}
                  fill="var(--color-plate)"
                  stroke="var(--color-ink)"
                  stroke-width="1"
                />
              ))}
            </>
          )}

          {/* Coastline on top so fills never bleed the edge. */}
          <path
            d={BANGLADESH_PATH}
            fill="none"
            stroke="var(--color-ink)"
            stroke-width="0.6"
            stroke-linejoin="round"
          />

          {/* N compass, lower-right. Decorative. */}
          <g transform="translate(224, 158)" aria-hidden="true">
            <line x1="0" y1="10" x2="0" y2="0" stroke="var(--color-ink-muted)" stroke-width="0.7" />
            <path d="M -2.2 3 L 0 -1.5 L 2.2 3 Z" fill="var(--color-ink-muted)" />
            <text
              x="0"
              y="17"
              text-anchor="middle"
              font-size="6"
              fill="var(--color-ink-muted)"
              style="font-family: var(--font-sans);"
            >N</text>
          </g>

          {/* Bay of Bengal — bottom-row panels only (canonical 3×2 layout). */}
          {BOTTOM_ROW_IDS.has(panel.id) && (
            <text
              x="120"
              y="176"
              text-anchor="middle"
              font-size="7"
              font-style="italic"
              fill="var(--color-ink-subtle)"
              style="font-family: var(--font-serif);"
              aria-hidden="true"
            >Bay of Bengal</text>
          )}
        </svg>
      </div>
    ))}
  </div>

  <!-- Figure footer: ramp legend, scale, scenario. -->
  <div class="sigviz__footer">
    <div class="sigviz__ramp" aria-label="Intensity ramp from low to high">
      <span class="sigviz__ramp-label">Net migration intensity</span>
      <span class="sigviz__ramp-end">low</span>
      <span class="sigviz__ramp-track" aria-hidden="true">
        {RAMP.slice(1).map((hex) => (
          <span class="sigviz__ramp-step" style={`background:${hex}`}></span>
        ))}
      </span>
      <span class="sigviz__ramp-end">high</span>
    </div>
    <div class="sigviz__scale" aria-label="Approximate scale">
      <span class="sigviz__scale-bar" aria-hidden="true"></span>
      <span>≈ 100 km</span>
    </div>
    <span class="sigviz__scenario">SSP2-4.5</span>
  </div>

  <!-- Simulation-time readout: labels the loop, 2025 → 2050. A progress
       indicator for simulation time, not an animated counter — it only
       exists while the figure plays. aria-hidden: the long-form text
       alternative carries the information. -->
  <div class="sigviz__timeline" aria-hidden="true">
    <span class="sigviz__timeline-label">simulation year</span>
    <span class="sigviz__year">
      {YEARS.map((year, i) => (
        <span class="ka-year" style={`--yd:${(i * YEAR_WIN_S).toFixed(3)}s; opacity:0;`}>{year}</span>
      ))}
    </span>
  </div>

  <figcaption class="sigviz__attribution">
    <em>Illustrative.</em> Synthetic geometry tuned to show the spatial
    grammar each architecture tends to produce; 3MIP's purpose is to make
    this divergence legible across real participating teams. Archetype
    lineages: Bell et al. 2019; Simini et al. 2012; Stouffer 1940; Rigaud
    et al. 2018; ISIMIP3 protocol; Schiavina et al. 2019.
    <span class="pending">[PENDING BELL APPROVAL]</span>
  </figcaption>
</figure>

<style define:vars={{ loop: `${LOOP_S}s`, tick: `${TICK_S}s` }}>
  .sigviz {
    margin-block: 0;
  }

  /* ── Header ─────────────────────────────────────────────────────── */
  .sigviz__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .sigviz__fig {
    margin: 0 0 var(--space-1);
  }
  .sigviz__title {
    font-family: var(--font-serif);
    font-variation-settings: var(--fraunces-h2);
    font-weight: 500;
    font-size: var(--text-h3);
    line-height: 1.25;
    color: var(--color-ink);
    margin: 0;
  }
  .sigviz__question {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    margin: var(--space-1) 0 0;
  }
  .sigviz__head-tools {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .sigviz__tag {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    color: var(--color-accent);
    border: var(--hairline) solid var(--color-border-strong);
    border-radius: 2px;
    padding: var(--space-1) var(--space-2);
  }

  /* Pause/play — ghost button (WCAG 2.2.2). Hidden until the controller
     enables it; display:none under reduced motion as a second guard. */
  .sigviz__toggle {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-ink);
    background: transparent;
