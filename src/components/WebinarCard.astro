---
/**
 * WebinarCard — one webinar on the Outputs page § Webinars.
 *
 * June 2026 changes (per Mario):
 *  - Speaker name + affiliation are now displayed (previously hidden).
 *  - The recording plays INLINE on this site, not by sending the visitor to
 *    Google Drive. Clicking the poster swaps it, in place, for an embedded
 *    Drive player (the file's /preview URL in an iframe). The iframe src is
 *    set only on click — no third-party request on page load — which keeps
 *    the Outputs page fast and private until the visitor chooses to watch.
 *    (This supersedes the earlier "external link, never iframe" stance for
 *    webinars; see DECISIONS-V2 D20.)
 *  - No-JS fallback: the poster is a real link to the recording, so without
 *    JavaScript it still opens (in Drive). With JS, playback stays on-site.
 */
import Button from "./Button.astro";

interface Speaker {
  name: string;
  affiliation: string;
}

interface Props {
  title: string;
  date: string;
  dateLabel: string;
  speakers?: Speaker[];
  lengthMinutes?: number;
  abstract?: string;
  recordingUrl?: string;
  slidesUrl?: string;
  /** Optional real frame-grab under /public, e.g. "webinars/2026-05.jpg". */
  poster?: string;
  needsVerify?: boolean;
}

const {
  title,
  date,
  dateLabel,
  speakers,
  lengthMinutes,
  abstract,
  recordingUrl,
  slidesUrl,
  poster,
  needsVerify = false,
}: Props = Astro.props;

// Build a Google Drive inline-player URL from the share link
// (https://drive.google.com/file/d/<ID>/view → .../<ID>/preview).
const driveId = recordingUrl?.match(/\/d\/([^/]+)/)?.[1];
const embedUrl = driveId ? `https://drive.google.com/file/d/${driveId}/preview` : undefined;
---

<article class="webinar">
  {recordingUrl && (
    <div class="webinar__media">
      <a
        class="webinar__poster"
        href={recordingUrl}
        rel="noopener noreferrer"
        data-webinar-play
        data-embed={embedUrl}
        aria-label={`Play the ${title} recording`}
        style={poster ? `background-image: url(/${poster}); background-size: cover; background-position: center;` : undefined}
      >
        <span class="webinar__play" aria-hidden="true">
          <svg viewBox="0 0 64 64" width="56" height="56">
            <circle cx="32" cy="32" r="31" fill="var(--color-accent)" />
            <path d="M26 21 L46 32 L26 43 Z" fill="var(--color-accent-ink)" />
          </svg>
        </span>
        <span class="webinar__poster-tag">{dateLabel}</span>
      </a>
      <iframe
        class="webinar__iframe"
        title={`${title} recording`}
        hidden
        allow="autoplay; fullscreen"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  )}

  <div class="webinar__body">
    <div class="webinar__meta">
      <time datetime={date} class="webinar__date">{dateLabel}</time>
      {lengthMinutes && <span class="webinar__len">{lengthMinutes} min</span>}
      {needsVerify && <span class="verify">[VERIFY]</span>}
    </div>

    <h3 class="webinar__title">{title}</h3>

    {speakers && speakers.length > 0 && (
      <p class="webinar__speakers">
        {speakers.map((s, i) => (
          <span>
            {s.name} <span class="webinar__affil">({s.affiliation})</span>{i < speakers.length - 1 ? "; " : ""}
          </span>
        ))}
      </p>
    )}

    {abstract && <p class="webinar__abstract">{abstract}</p>}

    {slidesUrl && (
      <div class="webinar__actions">
        <Button href={slidesUrl} external variant="ghost">Slides</Button>
      </div>
    )}
  </div>
</article>

<style>
  .webinar {
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  .webinar:first-of-type { border-top: 0; }
  @media (min-width: 640px) {
    .webinar {
      grid-template-columns: 22rem 1fr;
      gap: var(--space-5);
      align-items: start;
    }
  }

  /* Media: a 16:9 box that holds the poster, then the inline player. */
  .webinar__media {
    position: relative;
    aspect-ratio: 16 / 9;
    background-color: var(--color-plate);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .webinar__poster {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background-color 150ms var(--ease-out);
  }
  .webinar__poster:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: -2px;
  }
  .webinar__play {
    display: inline-flex;
    transition: transform 150ms var(--ease-out);
    filter: drop-shadow(0 2px 6px rgb(26 22 18 / 0.25));
  }
  .webinar__poster:hover .webinar__play { transform: scale(1.06); }
  .webinar__poster-tag {
    position: absolute;
    left: var(--space-2);
    bottom: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-plate) 85%, transparent);
    padding: 2px var(--space-2);
    border-radius: 2px;
  }
  .webinar__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .webinar__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .webinar__date {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
    font-weight: 500;
  }
  .webinar__len {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    letter-spacing: 0.06em;
  }
  .webinar__title {
    margin: var(--space-2) 0 var(--space-1);
    font-size: var(--text-h3);
  }
  .webinar__speakers {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink);
  }
  .webinar__affil { color: var(--color-ink-muted); }
  .webinar__abstract {
    margin: var(--space-3) 0 0;
    color: var(--color-ink-muted);
    max-width: 65ch;
  }
  .webinar__actions {
    margin-top: var(--space-4);
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
</style>

<!--
  Bundled (not inline) so it is included once per page regardless of how many
  WebinarCards render. Click the poster → swap it for the inline Drive player,
  setting the iframe src lazily (no Google request until the visitor watches).
  Without JS the poster is a normal link (opens the recording).
-->
<script>
  document.querySelectorAll<HTMLAnchorElement>("[data-webinar-play]").forEach((poster) => {
    poster.addEventListener("click", (e) => {
      const embed = poster.getAttribute("data-embed");
      const media = poster.closest(".webinar__media");
      const frame = media?.querySelector<HTMLIFrameElement>(".webinar__iframe");
      if (!embed || !frame) return; // no embed → fall through to the href
      e.preventDefault();
      frame.src = embed;
      frame.hidden = false;
      poster.style.display = "none";
    });
  });
</script>
