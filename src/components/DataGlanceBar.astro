---
/**
 * DataGlanceBar — a data-at-a-glance figure: a horizontal stacked bar showing
 * the real composition of the 16-dataset corpus across its three families
 * (7 / 5 / 4) in the family colors. This is data-derived ornament — it encodes
 * the actual corpus, so it's information, not decoration. Pure SVG with a text
 * alternative; the legend labels stay ink (the color is graphical only).
 */
interface Segment {
  label: string;
  count: number;
  /** Family color as a CSS value. */
  color: string;
}
interface Props {
  segments: Segment[];
}
const { segments }: Props = Astro.props;
const total = segments.reduce((s, x) => s + x.count, 0);
let acc = 0;
const parts = segments.map((s) => {
  const x = (acc / total) * 100;
  acc += s.count;
  return { ...s, x, w: (s.count / total) * 100 };
});
const alt = `The ${total} curated datasets by family: ${segments
  .map((s) => `${s.label}, ${s.count}`)
  .join("; ")}.`;
---

<figure class="glance">
  <svg viewBox="0 0 100 7" preserveAspectRatio="none" role="img" aria-label={alt} class="glance__bar">
    {parts.map((p) => (
      <rect x={p.x} y="0" width={p.w} height="7" fill={p.color} stroke="var(--color-background)" stroke-width="0.4" />
    ))}
  </svg>
  <ul class="glance__legend">
    {segments.map((s) => (
      <li class="glance__item">
        <span class="glance__dot" style={`background:${s.color}`}></span>
        <span>{s.label} <strong>{s.count}</strong></span>
      </li>
    ))}
  </ul>
</figure>

<style>
  .glance { margin: var(--space-4) 0; }
  .glance__bar {
    width: 100%;
    height: 0.85rem;
    display: block;
    border-radius: 3px;
    overflow: hidden;
  }
  .glance__legend {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
  }
  .glance__item {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-sans);
    font-size: var(--text-small);
    color: var(--color-ink-muted);
  }
  .glance__item strong { color: var(--color-ink); font-variant-numeric: tabular-nums; }
  .glance__dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
</style>
