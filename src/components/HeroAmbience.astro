---
/**
 * HeroAmbience — Tier 2 ambient motion (DECISIONS-V2 V9).
 *
 * A sparse field of 14 terracotta dots drifting very slowly southwest ↔
 * northeast — the ambience quotes the subject (the Bangladesh
 * coastal-to-Dhaka direction). 60–90s CSS-keyframe oscillations, zero JS.
 *
 * Quietness contract: a reader who never notices it loses nothing.
 *   - opacity 0.15–0.35, sizes 2–4px
 *   - aria-hidden, pointer-events: none
 *   - display: none entirely under prefers-reduced-motion
 *
 * The parent positions it (the Home hero places it over the right third
 * in Phase 4e). The component fills its container.
 *
 * Dots are hand-authored (deterministic). Each gets one of four drift
 * keyframes (a/b/c/d) at a distinct duration and negative delay so the
 * field is desynchronized from first paint.
 */
interface Props {
  class?: string;
}
const { class: className = "" }: Props = Astro.props;

// x/y as percentages of the container; r in px; o = opacity;
// k = drift keyframe variant; dur in s; delay (negative) in s.
const DOTS = [
  { x: 12, y: 18, r: 3, o: 0.28, k: "a", dur: 72, delay: -10 },
  { x: 28, y: 8,  r: 2, o: 0.18, k: "b", dur: 84, delay: -31 },
  { x: 44, y: 26, r: 4, o: 0.32, k: "c", dur: 66, delay: -52 },
  { x: 60, y: 12, r: 2, o: 0.2,  k: "d", dur: 90, delay: -18 },
  { x: 73, y: 30, r: 3, o: 0.26, k: "a", dur: 78, delay: -45 },
  { x: 88, y: 16, r: 2, o: 0.15, k: "b", dur: 62, delay: -7 },
  { x: 18, y: 48, r: 2, o: 0.22, k: "c", dur: 86, delay: -60 },
  { x: 36, y: 58, r: 3, o: 0.3,  k: "d", dur: 70, delay: -25 },
  { x: 55, y: 44, r: 2, o: 0.17, k: "a", dur: 88, delay: -40 },
  { x: 70, y: 62, r: 4, o: 0.34, k: "b", dur: 64, delay: -14 },
  { x: 85, y: 50, r: 2, o: 0.2,  k: "c", dur: 80, delay: -55 },
  { x: 25, y: 80, r: 3, o: 0.25, k: "d", dur: 74, delay: -3 },
  { x: 52, y: 86, r: 2, o: 0.16, k: "a", dur: 82, delay: -36 },
  { x: 78, y: 78, r: 3, o: 0.27, k: "b", dur: 68, delay: -21 },
] as const;
---

<div class={`ambience ${className}`} aria-hidden="true">
  {DOTS.map((d) => (
    <span
      class={`ambience__dot ambience__dot--${d.k}`}
      style={`left:${d.x}%; top:${d.y}%; width:${d.r}px; height:${d.r}px; opacity:${d.o}; animation-duration:${d.dur}s; animation-delay:${d.delay}s;`}
    ></span>
  ))}
</div>

<style>
  .ambience {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .ambience__dot {
    position: absolute;
    border-radius: 50%;
    background: var(--color-accent);
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    will-change: transform;
  }

  /* Four drift variants, all loosely southwest ↔ northeast (+x, −y),
     oscillating so the loop has no visible snap. */
  .ambience__dot--a { animation-name: drift-a; }
  .ambience__dot--b { animation-name: drift-b; }
  .ambience__dot--c { animation-name: drift-c; }
  .ambience__dot--d { animation-name: drift-d; }

  @keyframes drift-a {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(26px, -20px); }
  }
  @keyframes drift-b {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(34px, -16px); }
  }
  @keyframes drift-c {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(18px, -26px); }
  }
  @keyframes drift-d {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -28px); }
  }

  /* Gone — not paused — under reduced motion, per directive. */
  @media (prefers-reduced-motion: reduce) {
    .ambience { display: none; }
  }
</style>
