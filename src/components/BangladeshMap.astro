---
/**
 * BangladeshMap — stylized map of Bangladesh used on the Case 1 page
 * § Geographic scope.
 *
 * Reuses the same BANGLADESH_PATH as SignatureViz so the silhouette never
 * drifts between figures. Adds:
 *  - A subtle highlight band over the southern (coastal) belt — the coastal zone
 *  - A scale bar
 *
 * Physical geography only. 3MIP does not prescribe a fixed list of study
 * districts, so the map carries NO district markers or labels and is captioned
 * "Illustrative only — not an official study scope."
 * No satellite imagery, no district polygons. Schematic by design.
 * Per DESIGN-PRINCIPLES.md § Imagery — diagrams over photos.
 */
import { BANGLADESH_PATH } from "../lib/bangladesh-outline";

interface Props {
  class?: string;
}
const { class: className = "" }: Props = Astro.props;
---

<figure class={`bd-map ${className}`}>
  <svg
    viewBox="0 0 240 180"
    role="img"
    aria-labelledby="bd-map-title bd-map-desc"
    class="bd-map__svg"
  >
    <title id="bd-map-title">Coastal Bangladesh — schematic orientation map.</title>
    <desc id="bd-map-desc">
      Stylized outline of Bangladesh with a highlighted southern coastal belt
      along the Bay of Bengal. Illustrative only — not an official study scope;
      not satellite-accurate, schematic for orientation only.
    </desc>

    <defs>
      <clipPath id="bd-map-clip">
        <path d={BANGLADESH_PATH} />
      </clipPath>
    </defs>

    {/* Country fill — design-locked literal (DECISIONS-V2 V8), matching the
        signature viz land color so the two figures never drift apart. */}
    <path
      d={BANGLADESH_PATH}
      fill="#EEE7D7"
      stroke="var(--color-border-strong)"
      stroke-width="1.25"
    />

    {/* Coastal belt highlight — accent at low opacity, clipped to country */}
    <g clip-path="url(#bd-map-clip)">
      <rect
        x="0"
        y="130"
        width="240"
        height="60"
        fill="var(--color-accent)"
        opacity="0.18"
      />
    </g>

    {/* Outline on top so the highlight doesn't bleed */}
    <path
      d={BANGLADESH_PATH}
      fill="none"
      stroke="var(--color-ink)"
      stroke-width="1.25"
      stroke-linejoin="round"
    />

    {/* Scale bar bottom-left */}
    <g transform="translate(8, 172)">
      <rect x="0" y="0" width="36" height="2.5" fill="var(--color-ink)" />
      <text x="40" y="3" font-size="6" font-family="var(--font-sans)" fill="var(--color-ink-muted)">
        ~ 50 km
      </text>
    </g>
  </svg>
  <figcaption class="bd-map__caption">Illustrative only — not an official study scope.</figcaption>
</figure>

<style>
  .bd-map {
    margin: 0;
    width: 100%;
  }
  .bd-map__svg {
    width: 100%;
    height: auto;
    display: block;
    /* No own background — the figure mounts on the plate token (4e). */
    border-radius: var(--radius);
  }
  .bd-map__caption {
    margin-top: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    color: var(--color-ink-muted);
    letter-spacing: 0.01em;
  }
</style>
