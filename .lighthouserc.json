{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/about/index.html",
        "http://localhost/case-bangladesh/index.html",
        "http://localhost/data/index.html",
        "http://localhost/participate/index.html",
        "http://localhost/team/index.html",
        "http://localhost/outputs/index.html",
        "http://localhost/news/index.html",
        "http://localhost/contact/index.html",
        "http://localhost/dublin/index.html"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
