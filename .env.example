# 3MIP environment variables — copy to .env.local for local dev, or set in Vercel.
# .env* is gitignored; never commit real values.

# Formspree endpoint for the Participate registration form (archive/v1/DECISIONS.md D5).
# Create a form at https://formspree.io, then paste its endpoint here.
# Until set, the form renders but is inert and shows a "[PENDING]" note.
PUBLIC_FORMSPREE_ENDPOINT="https://formspree.io/f/REPLACE_WITH_FORM_ID"
